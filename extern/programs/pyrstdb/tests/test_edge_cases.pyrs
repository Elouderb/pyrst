# tests/test_edge_cases.pyrs — targeted edge-case matrix not covered by
# test_engine.pyrs: ORDER BY tie stability, LIMIT boundary values (0,
# negative, larger than row count), parse-error source positions, tokenizer
# errors (unterminated string / bad character), and run-to-run determinism
# (the same script run twice produces byte-identical stdout). Prints
# PASS/FAIL and exits 0/1.
#
# Run from extern/programs/pyrstdb/ after building both binaries:
#   pyrst build main.pyrs
#   pyrst build tests/test_edge_cases.pyrs
#   ./test_edge_cases            (optional arg: path to `main`, default "./main")

import sys
from subprocess import run, CompletedProcess

SCRIPT_PATH: str = "/tmp/pyrstdb_edge_script.sql"
ERR_SCRIPT_PATH: str = "/tmp/pyrstdb_edge_err_script.sql"


def binpath() -> str:
    if len(sys.argv) > 1:
        return sys.argv[1]
    return "./main"


def fail(message: str, out: str) -> None:
    print("FAIL: " + message + "\n----- output -----\n" + out)
    sys.exit(1)


def need(out: str, needle: str) -> None:
    if needle not in out:
        fail("missing expected output: " + needle, out)


def need_order(out: str, first: str, second: str) -> None:
    fi: int = out.find(first)
    si: int = out.find(second)
    if fi < 0:
        fail("missing (order check) first token: " + first, out)
    if si < 0:
        fail("missing (order check) second token: " + second, out)
    if fi >= si:
        fail("expected '" + first + "' before '" + second + "'", out)


def write_main_script() -> None:
    with open(SCRIPT_PATH, "w") as f:
        f.write("CREATE TABLE t (id INT, grp TEXT);\n")
        # tie group: three rows share grp='a', inserted in this order —
        # ORDER BY grp must keep them in original insertion order (stable).
        f.write("INSERT INTO t VALUES (1, 'a'), (2, 'b'), (3, 'a'), (4, 'a'), (5, 'b');\n")
        f.write("SELECT id, grp FROM t ORDER BY grp;\n")
        # LIMIT 0 -> zero rows, not an error
        f.write("SELECT id FROM t ORDER BY id LIMIT 0;\n")
        # LIMIT larger than row count -> all rows, no error, no padding
        f.write("SELECT id FROM t ORDER BY id LIMIT 1000;\n")
        # LIMIT negative -> zero rows (documented v1 edge)
        f.write("SELECT id FROM t ORDER BY id LIMIT -5;\n")
        f.write(".quit\n")


def write_err_script() -> None:
    with open(ERR_SCRIPT_PATH, "w") as f:
        # unterminated string literal
        f.write("SELECT * FROM t WHERE grp = 'unterminated;\n")
        # bad character
        f.write("SELECT * FROM t WHERE grp @ 'a';\n")
        # parse error position: 'FROM' misspelled -> error at a known offset
        f.write("SELECT * FRM t;\n")
        f.write(".quit\n")


def main() -> None:
    write_main_script()
    binary: str = binpath()
    r: CompletedProcess = run([binary, SCRIPT_PATH], capture_output=True)
    if r.returncode != 0:
        print("FAIL: main exited " + str(r.returncode))
        sys.exit(1)
    ob = r.stdout
    if ob is None:
        print("FAIL: no stdout")
        sys.exit(1)
        return
    out: str = ob.decode("utf-8")

    # ORDER BY tie stability: within grp='a', ids 1,3,4 must appear in that
    # relative order (insertion order preserved by the stable sort).
    need_order(out, "1  | a", "3  | a")
    need_order(out, "3  | a", "4  | a")

    # LIMIT 0 -> "(0 row(s))" and no data rows for that SELECT
    need(out, "(0 row(s))")

    # LIMIT 1000 (> row count) -> all 5 rows, no error
    need(out, "(5 row(s))")

    # LIMIT -5 -> zero rows, not an error
    # (already covered by the "(0 row(s))" needle above appearing at least
    # once; confirm it appears twice: once for LIMIT 0, once for LIMIT -5)
    zero_count: int = out.count("(0 row(s))")
    if zero_count < 2:
        fail("expected two '(0 row(s))' results (LIMIT 0 and LIMIT -5), found " + str(zero_count), out)

    # --- determinism: run the same script twice, expect identical stdout ---
    r2: CompletedProcess = run([binary, SCRIPT_PATH], capture_output=True)
    if r2.returncode != 0:
        print("FAIL: main exited " + str(r2.returncode) + " on second determinism run")
        sys.exit(1)
    ob2 = r2.stdout
    if ob2 is None:
        print("FAIL: no stdout on second determinism run")
        sys.exit(1)
        return
    out2: str = ob2.decode("utf-8")
    if out != out2:
        fail("same script produced different output across two runs (non-determinism)", out + "\n----- run 2 -----\n" + out2)

    # --- parse/tokenize error paths with source positions ---
    write_err_script()
    r3: CompletedProcess = run([binary, ERR_SCRIPT_PATH], capture_output=True)
    if r3.returncode != 0:
        print("FAIL: main exited " + str(r3.returncode) + " on error-script run")
        sys.exit(1)
    ob3 = r3.stdout
    if ob3 is None:
        print("FAIL: no stdout on error-script run")
        sys.exit(1)
        return
    out3: str = ob3.decode("utf-8")

    need(out3, "unterminated string literal at position")
    need(out3, "unexpected character '@' at position")
    # 'FRM' is not a keyword -> parser reports it as an IDENT/unexpected token
    # with a position; the exact wording is engine-owned, but a position must
    # be present.
    if "at position" not in out3:
        fail("expected a positional error for 'SELECT * FRM t;'", out3)

    print("PASS: test_edge_cases")
