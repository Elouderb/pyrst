def main() -> None:
    s: str = "hello-world-python"

    # partition
    parts: list[str] = s.partition("-")
    print(parts[0])
    print(parts[1])
    print(parts[2])

    # rpartition
    rparts: list[str] = s.rpartition("-")
    print(rparts[0])
    print(rparts[1])
    print(rparts[2])

    # partition with non-existent separator
    nparts: list[str] = s.partition("_")
    print(nparts[0])
    print(nparts[1])
    print(nparts[2])
