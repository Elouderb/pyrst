def make_adder(n: int) -> Callable[[int], int]:
    def add(x: int) -> int:
        return x + n
    return add

def apply_twice(n: int) -> int:
    def inc(x: int) -> int:
        return x + 1
    return inc(inc(n))

def main() -> None:
    add5: Callable[[int], int] = make_adder(5)
    print(add5(10))        # 15
    print(apply_twice(7))  # 9
