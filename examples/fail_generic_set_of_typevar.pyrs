# B5: a set element / dict key of a bare type variable lowers to HashSet<T> /
# HashMap<T, _>, which needs Hash+Eq (not provided by the `T: Clone` bound). It
# is an honest typeck error (E0277 otherwise) — covering set literals, set[T] /
# dict[K, _] annotations, and set/dict comprehensions uniformly.
def setof[T](a: T, b: T) -> set[T]:
    return {a, b}

def main() -> None:
    print(setof(1, 2))
