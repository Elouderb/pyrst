    d["ouml"] = True
    d["para"] = True
    d["plusmn"] = True
    d["pound"] = True
    d["quot"] = True
    d["raquo"] = True
    d["reg"] = True
    d["sect"] = True
    d["shy"] = True
    d["sup1"] = True
    d["sup2"] = True
    d["sup3"] = True
    d["szlig"] = True
    d["thorn"] = True
    d["times"] = True
    d["uacute"] = True
    d["ucirc"] = True
    d["ugrave"] = True
    d["uml"] = True
    d["uuml"] = True
    d["yacute"] = True
    d["yen"] = True
    d["yuml"] = True
    return d


# Resolve a captured named-charref `word` (the bare word chars, no leading
# `&` and no trailing `;` even if one was present in the input) against the
# entity table, honoring `had_semi` (whether the ORIGINAL input had a
# trailing `;` right after `word`). Mirrors CPython's `_replace_charref`
# longest-prefix search exactly (see module header for the dead-code proof
# behind starting the prefix scan at `len(word) - 1` in BOTH the
# had-semicolon and no-semicolon cases).
def _html_match_named(
    word: str, had_semi: bool, table: dict[str, int], no_semi: dict[str, bool]
) -> Optional[str]:
    if word in table:
        if had_semi or word in no_semi:
            return chr(table[word])
    wlen: int = len(word)
    x: int = wlen - 1
    while x > 1:
        prefix: str = word[0:x]
        if prefix in table and prefix in no_semi:
            suffix: str = word[x:wlen]
            tail: str = suffix + (";" if had_semi else "")
            return chr(table[prefix]) + tail
        x = x - 1
    return None


def unescape(s: str) -> str:
    if "&" not in s:
        return s
    table: dict[str, int] = _html_name2codepoint()
    no_semi: dict[str, bool] = _html_no_semi_names()
    result: str = ""
    i: int = 0
    n: int = len(s)
    while i < n:
        ch: str = s[i]
        if ch != "&":
            result += ch
            i = i + 1
            continue
        j: int = i + 1
        if j < n and s[j] == "#":
            k: int = j + 1
            is_hex: bool = k < n and (s[k] == "x" or s[k] == "X")
            digit_start: int = k + 1 if is_hex else k
            k2: int = digit_start
            if is_hex:
                while k2 < n and _html_is_hex_digit(s[k2]):
                    k2 = k2 + 1
            else:
                while k2 < n and _html_is_ascii_digit(s[k2]):
                    k2 = k2 + 1
            if k2 == digit_start:
                # No digits at all: not a charref (matches CPython — the
                # regex fails every alternative here). Literal '&', re-scan
                # from the very next char.
                result += "&"
                i = i + 1
                continue
            has_semi: bool = k2 < n and s[k2] == ";"
            value: int = 0
            di: int = digit_start
            if is_hex:
                while di < k2:
                    d: int = _html_hex_value(s[di])
                    if value <= 0x10FFFF:
                        value = value * 16 + d
                    di = di + 1
            else:
                while di < k2:
                    d2: int = _html_dec_value(s[di])
                    if value <= 0x10FFFF:
                        value = value * 10 + d2
                    di = di + 1
            result += _html_resolve_numeric(value)
            i = k2 + 1 if has_semi else k2
            continue
        # Named charref: capture up to 32 word chars, then an optional ';'.
        count: int = 0
        k3: int = j
        while k3 < n and count < 32 and _html_is_word_char(s[k3]):
            k3 = k3 + 1
            count = count + 1
        if count == 0:
            result += "&"
            i = i + 1
            continue
        word: str = s[j:k3]
        had_semi2: bool = k3 < n and s[k3] == ";"
        matched: Optional[str] = _html_match_named(word, had_semi2, table, no_semi)
        if matched is not None:
            result += matched
        else:
            result += "&" + word + (";" if had_semi2 else "")
        i = k3 + 1 if had_semi2 else k3
    return result
