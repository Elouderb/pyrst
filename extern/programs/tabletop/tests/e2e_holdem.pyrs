# e2e_holdem.pyrs — scripted-stdin end-to-end run through the real menu (main),
# verifying that under a NON-TTY stdin the app degrades honestly and still exits
# cleanly (exit 0, no hang).
#
# As of the live-board retrofit (card 73098a55), the whole app is ONE `terminal`
# alt screen that MAIN init()s once, and raw mode REQUIRES a real terminal (a TTY).
# Under scripted/piped stdin — as this harness runs it — main.init() raises an
# OSError-shaped exception BEFORE entering the alt screen; main prints an honest
# "needs a real terminal" line and exits 0 without reading stdin (the piped bytes
# are irrelevant, no hang). The menu never opens, so hold'em is not reached.
#
# Hold'em is now a live in-place poker table drawn directly on the shared Screen
# (PASS 3 — the temporary line-based suspend/resume bridge is GONE; every game is
# on the terminal library). The interactive game (hole/community reveal, pot/bets/
# stacks, betting via getch fold/check-call/raise with a getch raise-amount entry,
# showdown) is verified separately by driving a real PTY; the engine (evaluator +
# side pots) stays covered by test_holdem.pyrs.
#
# USAGE (from extern/programs/tabletop/):
#   pyrst build main.pyrs
#   pyrst build tests/e2e_holdem.pyrs
#   printf '' | ./e2e_holdem         # any piped/redirected stdin degrades main
#
# Same subprocess stdio-inheritance workaround as tests/smoke_main.pyrs
# (GAP: subprocess.run has no input= piping) — only the exit code is asserted.
import subprocess


def main() -> None:
    result = subprocess.run(["./main"], capture_output=False)
    if result.returncode == 0:
        print("PASS: non-tty main degrade (menu needs a TTY) exited cleanly (exit 0)")
    else:
        print(f"FAIL: main exited with code {result.returncode}")
        assert False
