def main() -> None:
    s: str = "hello-world-python"

    # partition returns a 3-TUPLE (str, str, str) — CPython's real shape.
    parts: tuple[str, str, str] = s.partition("-")
    print(parts[0])
    print(parts[1])
    print(parts[2])

    # tuple unpacking (the idiomatic configparser/csv pattern)
    head, sep, tail = s.rpartition("-")
    print(head)
    print(sep)
    print(tail)

    # partition with non-existent separator: (whole, "", "")
    a, b, c = s.partition("_")
    print(a)
    print(b)
    print(c)
