# W4-a (F8) negative: a `global n` declaration must PRECEDE every use of `n` in the
# same scope. CPython raises SyntaxError ("name 'counter' is used prior to global
# declaration"); pyrst accepted it before (applying the declaration whole-function
# regardless of position) — now an honest check error.
counter: int = 0

def f() -> int:
    seen: int = counter + 1
    global counter
    counter = seen
    return counter

def main() -> None:
    print(f())
