# blackjack.pyrs — 3-seat blackjack (player + 2 CPU seats) vs the dealer.
#
# Rules implemented (card f1ac8d46):
#   - 6-deck-style single Deck reshuffled when low; seeded shuffle.
#   - Soft-ace hand valuation (at most one ace counts as 11).
#   - Player hit/stand loop with robust re-prompting.
#   - 2 CPU seats play textbook BASIC STRATEGY (hard/soft tables vs dealer
#     upcard), hit/stand only.
#   - Dealer stands on all 17 (S17), hits 16 and below.
#   - Naturals (2-card 21) pay 3:2; natural vs natural pushes.
#   - Per-seat chip bankroll, flat 10-chip bet.
# DEFERRED (documented, card-scoped): splitting pairs and doubling-down are not
#   modelled — the CPU basic-strategy table is the hit/stand subset. Insurance
#   is not offered. See card f1ac8d46.

from cards import Card, Deck
import ui
# Live in-place card table on the `terminal` package (card 73098a55, PASS 3).
# NAME COLLISION note: blackjack defines NO colour-named constants, so no clash
# with terminal's RED/WHITE/BLACK; we still import colours SELECTIVELY (only the
# ones used) and use BRIGHT_RED for hearts/diamonds, BRIGHT_WHITE for spades/clubs
# per the card. `import ui` is kept only for the PURE suit_symbol formatter.
from terminal import Screen, GREEN, BLUE, BRIGHT_BLACK, BRIGHT_RED, BRIGHT_GREEN, BRIGHT_YELLOW, BRIGHT_CYAN, BRIGHT_WHITE
from ttscreen import clip, clip_pad

BET: int = 10
START_CHIPS: int = 100
RESHUFFLE_AT: int = 15


def card_hard_value(rank: int) -> int:
    # Ace counted as 1 here; softness handled by hand_total.
    if rank == 14:
        return 1
    if rank >= 11 and rank <= 13:
        return 10
    if rank == 10:
        return 10
    return rank


def upcard_value(c: Card) -> int:
    # Dealer upcard strength for strategy: Ace=11, faces/ten=10, else pip.
    if c.rank == 14:
        return 11
    if c.rank >= 10:
        return 10
    return c.rank


def hand_total(hand: list[Card]) -> int:
    base: int = 0
    aces: int = 0
    for c in hand:
        base = base + card_hard_value(c.rank)
        if c.rank == 14:
            aces = aces + 1
    if aces > 0 and base + 10 <= 21:
        return base + 10
    return base


def is_soft(hand: list[Card]) -> bool:
    base: int = 0
    aces: int = 0
    for c in hand:
        base = base + card_hard_value(c.rank)
        if c.rank == 14:
            aces = aces + 1
    return aces > 0 and base + 10 <= 21


def is_blackjack(hand: list[Card]) -> bool:
    return len(hand) == 2 and hand_total(hand) == 21


def card_face(c: Card) -> str:
    return c.rank_str() + ui.suit_symbol(c.suit)


def render_hand(hand: list[Card]) -> str:
    out: str = ""
    i: int = 0
    while i < len(hand):
        if i > 0:
            out = out + " "
        out = out + card_face(hand[i])
        i = i + 1
    return out


# --- CPU basic strategy (hit/stand subset). Returns True to HIT. -------------
def cpu_should_hit(hand: list[Card], dealer_up: int) -> bool:
    total: int = hand_total(hand)
    if is_soft(hand):
        if total >= 19:
            return False
        if total == 18:
            # Soft 18: stand vs 2-8, hit vs 9/10/Ace.
            if dealer_up >= 9:
                return True
            return False
        return True
    if total >= 17:
        return False
    if total >= 13:
        # Hard 13-16: stand vs 2-6, hit vs 7+.
        if dealer_up >= 7:
            return True
        return False
    if total == 12:
        # Hard 12: stand vs 4-6, else hit.
        if dealer_up >= 4 and dealer_up <= 6:
            return False
        return True
    return True


def seat_name(seat: int) -> str:
    if seat == 0:
        return "You"
    return f"CPU-{seat}"


# --- Settlement: +chips delta for one non-dealer hand vs the dealer. ---------
def settle(hand: list[Card], dealer: list[Card]) -> int:
    p: int = hand_total(hand)
    d: int = hand_total(dealer)
    p_bj: bool = is_blackjack(hand)
    d_bj: bool = is_blackjack(dealer)
    if p_bj and d_bj:
        return 0
    if p_bj:
        return (BET * 3) // 2
    if d_bj:
        return -BET
    if p > 21:
        return -BET
    if d > 21:
        return BET
    if p > d:
        return BET
    if p < d:
        return -BET
    return 0


# --- interactive game (live in-place card table on the `terminal` alt screen) --
#
# The PURE blackjack engine above (hand_total / is_soft / is_blackjack / settle /
# cpu_should_hit / upcard_value, and the dealing / dealer-stands-on-17 / 3:2 flow)
# is UNCHANGED — this section only replaces the old line-based print + prompt_yes_no
# I/O with a full-screen, live-redrawing card table (card 73098a55, PASS 3),
# mirroring the checkers/chess retrofit. The Screen LIFECYCLE is owned by main:
# the whole app is ONE shared alt-screen session; play_blackjack just draws onto
# the passed-in `s` and returns to the menu on quit. main handles the non-TTY
# degrade; there is nothing to init/close here (the temporary suspend/resume
# bridge is gone).
#
# COORDINATES are (x, y) = (col, row), 0-based from the top-left.
#
# card_face / render_hand above stay byte-identical but are no longer used by the
# program (the live table draws colour-per-suit cells) — same as chess `render`
# and checkers `ck_render`, kept for potential test/debug use.

# Card-cell geometry. Each card is drawn as a small "chip" cell BJ_CARD_W wide
# with a 1-col gap; a face-up card shows a colour-coded rank+suit, a face-down
# card shows a blue back. Fixed strides mean the multi-byte unicode suit glyphs
# (1 display column each) never need width math.
BJ_CARD_W: int = 5
BJ_CARD_STRIDE: int = 6
BJ_CARD_BG: int = BRIGHT_BLACK     # grey "card" background (glyphs stay legible)
BJ_BACK_BG: int = BLUE             # face-down back
BJ_MIN_COLS: int = 52
BJ_MIN_ROWS: int = 18

# Seat display rows.
BJ_DEALER_ROW: int = 3
BJ_SEAT_ROWS: list[int] = [7, 10, 13]
BJ_CARDS_X: int = 12


def bj_suit_fg(suit: str) -> int:
    # hearts/diamonds -> BRIGHT_RED, spades/clubs -> BRIGHT_WHITE (card spec).
    if suit == "H" or suit == "D":
        return BRIGHT_RED
    return BRIGHT_WHITE


def bj_draw_card(s: Screen, x: int, y: int, c: Card) -> None:
    face: str = c.rank_str() + ui.suit_symbol(c.suit)
    s.set_bg(BJ_CARD_BG)
    s.set_fg(bj_suit_fg(c.suit))
    s.bold(True)
    s.addstr(x, y, " " * BJ_CARD_W)   # the grey cell
    s.addstr(x + 1, y, face)          # rank+suit, colour-coded, on the cell
    s.bold(False)
    s.reset_style()


def bj_draw_back(s: Screen, x: int, y: int) -> None:
    s.set_bg(BJ_BACK_BG)
    s.set_fg(BRIGHT_WHITE)
    s.bold(True)
    s.addstr(x, y, " " * BJ_CARD_W)
    s.addstr(x + 1, y, "##")
    s.bold(False)
    s.reset_style()


def bj_draw_hand(s: Screen, x: int, y: int, hand: list[Card], hide_hole: bool, cols: int) -> None:
    # Draw each card left-to-right at a fixed stride; when hide_hole, index 0 (the
    # dealer upcard) stays face-up and the rest are backs. Cards that would run off
    # the right edge are skipped (rare very-long hands) — totals still render.
    i: int = 0
    while i < len(hand):
        cx: int = x + i * BJ_CARD_STRIDE
        if cx + BJ_CARD_W > cols:
            return
        if hide_hole and i >= 1:
            bj_draw_back(s, cx, y)
        else:
            bj_draw_card(s, cx, y, hand[i])
        i = i + 1


def bj_seat_status(hand: list[Card]) -> str:
    if hand_total(hand) > 21:
        return "BUST"
    if is_blackjack(hand):
        return "BLACKJACK"
    return ""


def bj_draw(s: Screen, chips: list[int], seats: list[list[Card]], dealer: list[Card],
            hide_hole: bool, status: str, help_line: str, active_seat: int,
            notes: list[str]) -> None:
    size: tuple[int, int] = s.size()
    cols: int = size[0]
    rows: int = size[1]
    s.clear()
    if cols < BJ_MIN_COLS or rows < BJ_MIN_ROWS:
        s.set_fg(BRIGHT_RED)
        s.bold(True)
        s.addstr(0, 0, clip("Blackjack needs a bigger terminal: " + str(BJ_MIN_COLS) + "x" + str(BJ_MIN_ROWS) + " min, have " + str(cols) + "x" + str(rows) + ". Resize, then press any key.", cols))
        s.reset_style()
        s.refresh()
        return

    # status bar (row 0)
    bar: str = " BLACKJACK    chips  You:" + str(chips[0]) + "  CPU-1:" + str(chips[1]) + "  CPU-2:" + str(chips[2]) + " "
    s.set_fg(BRIGHT_WHITE)
    s.reverse(True)
    s.bold(True)
    s.addstr(0, 0, clip_pad(bar, cols))
    s.reset_style()

    # transient status message (row 1)
    s.set_fg(BRIGHT_YELLOW)
    s.addstr(0, 1, clip(status, cols))
    s.reset_style()

    # dealer
    dlabel: str = "Dealer"
    if hide_hole:
        dlabel = dlabel + "  (shows " + str(upcard_value(dealer[0])) + ")"
    else:
        dt: int = hand_total(dealer)
        dlabel = dlabel + "  (total " + str(dt) + ")"
        if dt > 21:
            dlabel = dlabel + "  BUST"
    s.set_fg(BRIGHT_CYAN)
    s.bold(True)
    s.addstr(2, BJ_DEALER_ROW, clip(dlabel, cols - 2))
    s.bold(False)
    s.reset_style()
    bj_draw_hand(s, BJ_CARDS_X, BJ_DEALER_ROW + 1, dealer, hide_hole, cols)

    # three seats
    si: int = 0
    while si < 3:
        y: int = BJ_SEAT_ROWS[si]
        label: str = seat_name(si) + "  (total " + str(hand_total(seats[si])) + ")"
        st: str = bj_seat_status(seats[si])
        if st != "":
            label = label + "  " + st
        if si < len(notes) and notes[si] != "":
            label = label + "   " + notes[si]
        if si == active_seat:
            s.set_fg(BRIGHT_YELLOW)
            s.reverse(True)
            s.bold(True)
            s.addstr(2, y, clip_pad("> " + label, 30))
            s.reset_style()
        else:
            s.set_fg(BRIGHT_WHITE)
            s.addstr(2, y, clip("  " + label, cols - 2))
            s.reset_style()
        bj_draw_hand(s, BJ_CARDS_X, y + 1, seats[si], False, cols)
        si = si + 1

    # help footer
    hr: int = rows - 1
    s.set_fg(BRIGHT_WHITE)
    s.reverse(True)
    s.addstr(0, hr, clip_pad(" " + help_line + " ", cols))
    s.reset_style()
    s.refresh()


def bj_wait_key(s: Screen) -> str:
    return s.getch()


def bj_notice(s: Screen, msg: str) -> None:
    # A simple full-screen centred notice (no table) for terminal-state messages.
    size: tuple[int, int] = s.size()
    cols: int = size[0]
    rows: int = size[1]
    s.clear()
    s.set_fg(BRIGHT_YELLOW)
    s.bold(True)
    s.addstr(2, rows // 2, clip(msg, cols - 2))
    s.set_fg(BRIGHT_WHITE)
    s.reverse(True)
    s.addstr(0, rows - 1, clip_pad(" press any key to return to the menu ", cols))
    s.reset_style()
    s.refresh()
    ignored_n: str = s.getch()


def play_blackjack(s: Screen, seed: int) -> None:
    deck: Deck = Deck()
    deck.shuffle(seed)
    round_seed: int = seed

    chips: list[int] = [START_CHIPS, START_CHIPS, START_CHIPS]
    no_notes: list[str] = []

    while True:
        if chips[0] < BET:
            bj_notice(s, "You're out of chips. Thanks for playing!")
            return

        if deck.remaining() < RESHUFFLE_AT:
            deck = Deck()
            round_seed = round_seed + 1
            deck.shuffle(round_seed)

        # Deal: three seats + dealer, two cards each. (Dealing logic UNCHANGED.)
        seat0: list[Card] = []
        seat1: list[Card] = []
        seat2: list[Card] = []
        seats: list[list[Card]] = [seat0, seat1, seat2]
        dealer: list[Card] = []
        deal_round: int = 0
        while deal_round < 2:
            sd: int = 0
            while sd < 3:
                seats[sd].append(deck.draw())
                sd = sd + 1
            dealer.append(deck.draw())
            deal_round = deal_round + 1

        dealer_up: int = upcard_value(dealer[0])

        # Player seat (0): live hit/stand loop (dealer hole face-down). Logic
        # (hand_total gate) UNCHANGED; only the y/n prompt becomes getch.
        quit_to_menu: bool = False
        if is_blackjack(seats[0]):
            bj_draw(s, chips, seats, dealer, True, "Blackjack! You have 21.",
                    "any key: continue    q: quit to menu", 0, no_notes)
            k0: str = s.getch()
            if k0 == "q" or k0 == "ctrl+c" or k0 == "esc":
                return
        else:
            while hand_total(seats[0]) < 21:
                bj_draw(s, chips, seats, dealer, True, "Your move — hit or stand?",
                        "h/y: hit    s/n: stand    q: quit to menu", 0, no_notes)
                k1: str = s.getch()
                if k1 == "q" or k1 == "ctrl+c" or k1 == "esc":
                    quit_to_menu = True
                    break
                if k1 == "h" or k1 == "y":
                    seats[0].append(deck.draw())
                    continue
                if k1 == "s" or k1 == "n" or k1 == "enter" or k1 == "space":
                    break
                # any other key re-prompts (redraws)
        if quit_to_menu:
            return

        # CPU seats (1,2): textbook basic strategy. Logic UNCHANGED.
        s2: int = 1
        while s2 < 3:
            while hand_total(seats[s2]) < 21 and cpu_should_hit(seats[s2], dealer_up):
                seats[s2].append(deck.draw())
            s2 = s2 + 1

        # Dealer plays (reveal hole, hit below 17). Logic UNCHANGED.
        any_alive: bool = False
        alive_check: int = 0
        while alive_check < 3:
            if hand_total(seats[alive_check]) <= 21:
                any_alive = True
            alive_check = alive_check + 1
        if any_alive:
            while hand_total(dealer) < 17:
                dealer.append(deck.draw())

        # Settle every seat (3:2 naturals, dealer-stands-17). Logic UNCHANGED.
        notes: list[str] = ["", "", ""]
        seat_i: int = 0
        while seat_i < 3:
            delta: int = settle(seats[seat_i], dealer)
            chips[seat_i] = chips[seat_i] + delta
            verdict: str = "push"
            if delta > 0:
                verdict = "wins +" + str(delta)
            elif delta < 0:
                verdict = "loses " + str(delta)
            notes[seat_i] = verdict
            seat_i = seat_i + 1

        # Result frame (dealer revealed), then the between-rounds prompt.
        if chips[0] < BET:
            bj_draw(s, chips, seats, dealer, False, "Round over — you're out of chips.",
                    "press any key to return to the menu", -1, notes)
            ignored_b: str = bj_wait_key(s)
            return
        bj_draw(s, chips, seats, dealer, False, "Round over — you have " + str(chips[0]) + " chips. Play another?",
                "y/enter: another round    n/q: quit to menu", -1, notes)
        k2: str = s.getch()
        if k2 == "n" or k2 == "q" or k2 == "ctrl+c" or k2 == "esc":
            return
