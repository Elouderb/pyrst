# HONEST REJECTION (card c34ac64a fix D): filter() needs a predicate AND an
# iterable. Under-arity (fewer than 2 args) ICE'd at BUILD; now an honest CHECK
# arity error ("filter expected 2 arguments, got 1", CPython 3.12).
def pos(x: int) -> bool:
    return x > 0


def main() -> None:
    xs = list(filter(pos))
    print(xs)
