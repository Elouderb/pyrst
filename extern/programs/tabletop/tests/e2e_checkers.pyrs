# e2e_checkers.pyrs — scripted-stdin end-to-end run through the real menu (main),
# verifying that under a NON-TTY stdin the app degrades honestly and still exits
# cleanly (exit 0, no hang).
#
# As of the single-shared-Screen retrofit (card 73098a55, PASS 2), it is MAIN
# itself that opens the `terminal` alt-screen session: main.init() enables raw
# mode ONCE for the whole app (the menu + all games run on that one Screen). Raw
# mode REQUIRES a real terminal (a TTY). Under scripted/piped stdin — as this
# harness runs it — main.init() raises an OSError-shaped exception BEFORE entering
# the alt screen; main prints an honest "needs a real terminal" line and exits 0,
# with nothing to restore. The menu never opens, so no game (checkers included) is
# reached under a pipe. The interactive checkers game (arrow-cursor piece +
# destination selection, highlighted legal moves, coloured pieces) is verified
# separately by driving a real PTY; the pure move-gen / rules stay covered by
# test_checkers.pyrs.
#
# USAGE (from extern/programs/tabletop/):
#   pyrst build main.pyrs
#   pyrst build tests/e2e_checkers.pyrs
#   printf '' | ./e2e_checkers      # any piped/redirected stdin degrades main
#
# Because main degrades at startup under a pipe, the piped bytes are irrelevant
# (main never reads stdin): it prints the honest message and exits 0. Only the
# exit code is asserted.
#
# Same subprocess stdio-inheritance workaround as tests/smoke_main.pyrs
# (GAP: subprocess.run has no input= piping) — capture_output=False INHERITS this
# process's stdio, so piping into THIS binary flows through to ./main's stdin.
# Only the exit code is asserted here.
import subprocess


def main() -> None:
    result = subprocess.run(["./main"], capture_output=False)
    if result.returncode == 0:
        print("PASS: non-tty main degrade (menu needs a TTY) exited cleanly (exit 0)")
    else:
        print(f"FAIL: main exited with code {result.returncode}")
        assert False
