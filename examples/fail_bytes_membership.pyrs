# W5-b HONEST REJECTION: `int in bytes` and `bytes in bytes` are now supported, but
# `str in bytes` stays a type error — CPython raises TypeError ("a bytes-like object
# is required, not 'str'"). pyrst rejects it at CHECK (decode/encode to bridge str
# and bytes) rather than letting the loose generic membership path leak a rustc error.
def main() -> None:
    print("A" in b"ABC")
