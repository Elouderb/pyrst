# oracle_matrix.pyrs — comprehensive oracle matrix for tzdata (card 965bf13f).
#
# Every asserted (offset, is_dst) value below was EXTRACTED FROM python3.12
# `zoneinfo` (scratchpad/genmatrix.py) — this is the oracle-pinned correctness
# matrix the card requires: each DST zone at mid-winter + mid-summer noon 2026,
# plus local noon on the day BEFORE and the day AFTER every real 2026 DST
# transition (the +/-1-day boundary probe; noon is always outside the
# ambiguous/nonexistent hour), each no-DST zone at a fixed instant, and a
# spanning sample of the Etc/GMT fixed-offset family. 212 probes, 424 assertions.
#
# Build from the package dir:
#   PYRST_PATH=/home/ethos/Coding/pyrst/extern/packages \
#     /home/ethos/Coding/pyrst/target/release/pyrst build tests/oracle_matrix.pyrs
#   ./oracle_matrix        # prints PASS: oracle_matrix / exit 0, or FAIL lines / exit 1

import sys
from tzdata.api import utc_offset_at, is_dst_at


def check(label: str, got: int, want: int, failures: Mut[list[str]]) -> None:
    if got != want:
        failures.append(label + ": got " + str(got) + ", want " + str(want))


def check_bool(label: str, got: bool, want: bool, failures: Mut[list[str]]) -> None:
    if got != want:
        failures.append(label + ": got " + str(got) + ", want " + str(want))


def main() -> None:
    failures: list[str] = []

    check("UTC 2026-01-15", utc_offset_at("UTC", 2026, 1, 15, 12, 0), 0, failures)
    check_bool("UTC dst 2026-01-15", is_dst_at("UTC", 2026, 1, 15, 12, 0), False, failures)
    check("UTC 2026-07-15", utc_offset_at("UTC", 2026, 7, 15, 12, 0), 0, failures)
    check_bool("UTC dst 2026-07-15", is_dst_at("UTC", 2026, 7, 15, 12, 0), False, failures)
    check("America/New_York 2026-01-15", utc_offset_at("America/New_York", 2026, 1, 15, 12, 0), -300, failures)
    check_bool("America/New_York dst 2026-01-15", is_dst_at("America/New_York", 2026, 1, 15, 12, 0), False, failures)
    check("America/New_York 2026-07-15", utc_offset_at("America/New_York", 2026, 7, 15, 12, 0), -240, failures)
    check_bool("America/New_York dst 2026-07-15", is_dst_at("America/New_York", 2026, 7, 15, 12, 0), True, failures)
