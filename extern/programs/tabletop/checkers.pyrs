# checkers.pyrs — American (English draughts) checkers vs a minimax CPU.
#
# Rules implemented (card f1ac8d46):
#   - 8x8 board on dark squares ((row+col) odd). Player = Red (r/R), moves UP
#     (toward row 0); CPU = White (w/W), moves DOWN (toward row 7).
#   - Men move/capture one diagonal forward; kings both directions.
#   - FORCED CAPTURE: if any capture exists for the side to move, only captures
#     are legal, and each jump sequence must be MAXIMAL (multi-jumps continue).
#   - Kinging on the far row. American rule: a man that reaches the king row by
#     a jump PROMOTES and the move ends (no continued jump as a king that turn).
#   - Draw claimed after 40 plies with no capture (simple stall guard).
# Move generation is pure (board = list[int] of 64, +1/+2 red man/king,
# -1/-2 white man/king, 0 empty), separated from I/O, and unit-tested in
# test_checkers.pyrs (forced-capture / multi-jump / promotion / perft-lite).

# Live in-place board rendering runs on the `terminal` package (card 8e858f68).
# NOTE: `terminal` also exports colour constants named RED/WHITE, which would
# clobber checkers' own RED=+1 / WHITE=-1 SIDE constants below — so we import
# ONLY the non-colliding colour names and use BRIGHT_RED/BRIGHT_WHITE for the two
# sides' pieces. The pure move-gen/rules logic keeps using RED/WHITE as sides.
from terminal import Screen, BLACK, GREEN, BLUE, BRIGHT_BLACK, BRIGHT_RED, BRIGHT_YELLOW, BRIGHT_CYAN, BRIGHT_WHITE

RED: int = 1
WHITE: int = -1

# --- coordinates -------------------------------------------------------------
def rc_row(sq: int) -> int:
    return sq // 8


def rc_col(sq: int) -> int:
    return sq % 8


def sq_of(r: int, c: int) -> int:
    return r * 8 + c


def on_board(r: int, c: int) -> bool:
    return r >= 0 and r < 8 and c >= 0 and c < 8


def is_king_row(sq: int, side: int) -> bool:
    if side == RED:
        return rc_row(sq) == 0
    return rc_row(sq) == 7


def alg(sq: int) -> str:
    c: int = rc_col(sq)
    r: int = rc_row(sq)
    letter: str = chr(ord('a') + c)
    return letter + str(8 - r)


# --- move type ---------------------------------------------------------------
class CMove:
    path: list[int]
    caps: list[int]

    def __init__(self, path: list[int], caps: list[int]) -> None:
        self.path = path
        self.caps = caps

    def frm(self) -> int:
        return self.path[0]

    def dst(self) -> int:
        return self.path[len(self.path) - 1]

    def is_jump(self) -> bool:
        return len(self.caps) > 0

    def label(self) -> str:
        sep: str = "-"
        if self.is_jump():
            sep = "x"
        out: str = alg(self.path[0])
        i: int = 1
        while i < len(self.path):
            out = out + sep + alg(self.path[i])
            i = i + 1
        return out


# --- board setup -------------------------------------------------------------
def new_board() -> list[int]:
    b: list[int] = [0] * 64
    r: int = 0
    while r < 8:
        c: int = 0
        while c < 8:
            if (r + c) % 2 == 1:
                if r <= 2:
                    b[sq_of(r, c)] = WHITE
                elif r >= 5:
                    b[sq_of(r, c)] = RED
            c = c + 1
        r = r + 1
    return b


def piece_side(v: int) -> int:
    if v > 0:
        return RED
    if v < 0:
        return WHITE
    return 0


def is_king(v: int) -> bool:
    return v == 2 or v == -2


# Direction sets as (dr, dc).
def man_dirs(side: int) -> list[tuple[int, int]]:
    if side == RED:
        return [(-1, -1), (-1, 1)]
    return [(1, -1), (1, 1)]


def all_dirs() -> list[tuple[int, int]]:
    return [(-1, -1), (-1, 1), (1, -1), (1, 1)]


def dirs_for(v: int, side: int) -> list[tuple[int, int]]:
    if is_king(v):
        return all_dirs()
    return man_dirs(side)


# --- capture (jump) generation ----------------------------------------------
def dfs_jumps(b: list[int], side: int, cur: int, king_now: bool,
              captured: list[int], path: list[int], out: Mut[list[CMove]]) -> None:
    r: int = rc_row(cur)
    c: int = rc_col(cur)
    piece_val: int = 2 * side
    if not king_now:
        piece_val = side
    dirs: list[tuple[int, int]] = dirs_for(piece_val, side)
    extended: bool = False
    for d in dirs:
        dr: int = d[0]
        dc: int = d[1]
        mr: int = r + dr
        mc: int = c + dc
        lr: int = r + 2 * dr
        lc: int = c + 2 * dc
        if not on_board(lr, lc):
            continue
        mid: int = sq_of(mr, mc)
        land: int = sq_of(lr, lc)
        # Enemy on mid (not already captured this sequence), empty landing.
        if b[mid] * side >= 0:
            continue
        if mid in captured:
            continue
        if b[land] != 0:
            continue
        promoted: bool = (not king_now) and is_king_row(land, side)
        new_caps: list[int] = captured[:]
        new_caps.append(mid)
        new_path: list[int] = path[:]
        new_path.append(land)
        extended = True
        if promoted:
            # American rule: promotion ends the move.
            out.append(CMove(new_path, new_caps))
        else:
            dfs_jumps(b, side, land, king_now, new_caps, new_path, out)
    if not extended and len(path) > 1:
        out.append(CMove(path[:], captured[:]))


def gen_jumps(b: list[int], side: int) -> list[CMove]:
    out: list[CMove] = []
    sq: int = 0
    while sq < 64:
        if b[sq] * side > 0:
            king_now: bool = is_king(b[sq])
            start_path: list[int] = [sq]
            start_caps: list[int] = []
            dfs_jumps(b, side, sq, king_now, start_caps, start_path, out)
        sq = sq + 1
    return out


def gen_simple(b: list[int], side: int) -> list[CMove]:
    out: list[CMove] = []
    sq: int = 0
    while sq < 64:
        if b[sq] * side > 0:
            r: int = rc_row(sq)
            c: int = rc_col(sq)
            dirs: list[tuple[int, int]] = dirs_for(b[sq], side)
            for d in dirs:
                nr: int = r + d[0]
                nc: int = c + d[1]
                if on_board(nr, nc):
                    ns: int = sq_of(nr, nc)
                    if b[ns] == 0:
                        out.append(CMove([sq, ns], []))
        sq = sq + 1
    return out


# Legal moves: captures are forced when any exist.
def gen_moves(b: list[int], side: int) -> list[CMove]:
    jumps: list[CMove] = gen_jumps(b, side)
    if len(jumps) > 0:
        return jumps
    return gen_simple(b, side)


def ck_apply_move(b: list[int], side: int, m: CMove) -> list[int]:
    nb: list[int] = b[:]
    frm: int = m.frm()
    dst: int = m.dst()
    v: int = nb[frm]
    nb[frm] = 0
    for cap in m.caps:
        nb[cap] = 0
    if not is_king(v) and is_king_row(dst, side):
        v = 2 * side
    nb[dst] = v
    return nb


# --- evaluation (positive favors RED) ---------------------------------------
def raw_eval(b: list[int]) -> int:
    score: int = 0
    sq: int = 0
    while sq < 64:
        v: int = b[sq]
        if v != 0:
            r: int = rc_row(sq)
            if v == RED:
                score = score + 100 + (7 - r)  # advancement toward row 0
            elif v == 2:
                score = score + 175
            elif v == WHITE:
                score = score - 100 - r
            elif v == -2:
                score = score - 175
        sq = sq + 1
    return score


BIG: int = 1000000


def ck_negamax(b: list[int], side: int, depth: int, alpha: int, beta: int) -> int:
    moves: list[CMove] = gen_moves(b, side)
    if len(moves) == 0:
        return -BIG - depth  # side to move has no move: loss (prefer slower loss)
    if depth == 0:
        # side-relative static eval + light mobility term.
        opp_moves: int = len(gen_moves(b, -side))
        mob: int = (len(moves) - opp_moves) * 2
        return raw_eval(b) * side + mob
    best: int = -BIG * 4
    a: int = alpha
    for m in moves:
        nb: list[int] = ck_apply_move(b, side, m)
        v: int = -ck_negamax(nb, -side, depth - 1, -beta, -a)
        if v > best:
            best = v
        if best > a:
            a = best
        if a >= beta:
            break
    return best


def choose_cpu_move(b: list[int], side: int, depth: int) -> int:
    """Returns index into gen_moves(b, side) of the CPU's chosen move (-1 none)."""
    moves: list[CMove] = gen_moves(b, side)
    if len(moves) == 0:
        return -1
    best_idx: int = 0
    best_val: int = -BIG * 8
    i: int = 0
    while i < len(moves):
        nb: list[int] = ck_apply_move(b, side, moves[i])
        v: int = -ck_negamax(nb, -side, depth - 1, -BIG * 8, BIG * 8)
        if v > best_val:
            best_val = v
            best_idx = i
        i = i + 1
    return best_idx


def count_pieces(b: list[int], side: int) -> int:
    n: int = 0
    sq: int = 0
    while sq < 64:
        if b[sq] * side > 0:
            n = n + 1
        sq = sq + 1
    return n


# --- rendering ---------------------------------------------------------------
def ck_glyph(v: int) -> str:
    if v == RED:
        return "r"
    if v == 2:
        return "R"
    if v == WHITE:
        return "w"
    if v == -2:
        return "W"
    return "."


def ck_render(b: list[int]) -> str:
    out: str = "     a   b   c   d   e   f   g   h\n"
    out = out + "   +" + ("---+" * 8) + "\n"
    r: int = 0
    while r < 8:
        rank: str = str(8 - r)
        line: str = " " + rank + " |"
        c: int = 0
        while c < 8:
            sq: int = sq_of(r, c)
            cell: str = " "
            if (r + c) % 2 == 1:
                cell = ck_glyph(b[sq])
            line = line + " " + cell + " |"
            c = c + 1
        out = out + line + " " + rank + "\n"
        out = out + "   +" + ("---+" * 8) + "\n"
        r = r + 1
    out = out + "     a   b   c   d   e   f   g   h"
    return out


# --- interactive game (live in-place board on the `terminal` alt screen) ------
#
# The PURE move-gen/rules above are UNCHANGED — this section only replaces the
# old line-based presentation + input with a full-screen, live-redrawing board:
# an arrow-key cursor selects a piece then a destination, legal destinations are
# highlighted (reusing gen_moves for the hints), colour marks the two sides and
# kings, and a status line shows the turn / CPU thinking / result.
#
# The Screen LIFECYCLE is owned by main.pyrs (PASS 2, card 73098a55): the whole
# app is ONE shared alt-screen session — main init()s the Screen once, dispatches
# play_checkers(s) with that already-open Screen, and close()s it once in a
# finally. So play_checkers no longer creates/init()s/close()s its own Screen (and
# there is no non-TTY handling here: main degrades before ever dispatching a
# game); it simply runs on the passed-in `s` and returns to the menu on quit.
#
# COORDINATES are (x, y) = (col, row), 0-based from the top-left (the terminal
# package convention — the opposite of curses' (y, x)).
CPU_DEPTH: int = 7

# Piece colours (fg): the two sides + kings (kings additionally drawn bold).
PIECE_RED_FG: int = BRIGHT_RED
PIECE_WHITE_FG: int = BRIGHT_WHITE

# Square backgrounds + highlight colours.
BG_DARK: int = BLACK          # playable (dark) squares — pieces live here
BG_LIGHT: int = BRIGHT_BLACK  # non-playable (light) squares
BG_CURSOR: int = BRIGHT_YELLOW  # the roaming cursor square (highest priority)
BG_SRC: int = BRIGHT_CYAN     # the currently-selected source square
BG_DST: int = GREEN           # a legal destination for the selected piece
BG_MOVABLE: int = BLUE        # a piece that has at least one legal move (hint)

# Board geometry: each square is CELLW cols x CELLH rows; the board is centred
# horizontally and starts at row BOARD_Y0. Sized to fit a standard 80x24.
CELLW: int = 6
CELLH: int = 2
BOARD_Y0: int = 3
MIN_COLS: int = 8 * CELLW + 5   # board + left margin (ox>=3) + right rank label
MIN_ROWS: int = BOARD_Y0 + 8 * CELLH + 3


# ── small string helpers (frame-safe clipping) ───────────────────────────────
def ck_clip(text: str, w: int) -> str:
    if len(text) > w:
        return text[0:w]
    return text


def ck_clip_pad(text: str, w: int) -> str:
    if len(text) >= w:
        return text[0:w]
    return text + " " * (w - len(text))


# ── move-selection helpers (reuse the pure move list for UI hints) ────────────
def moves_from(moves: list[CMove], src: int) -> list[CMove]:
    out: list[CMove] = []
    for m in moves:
        if m.frm() == src:
            out.append(m)
    return out


def dsts_of(ms: list[CMove]) -> list[int]:
    out: list[int] = []
    for m in ms:
        out.append(m.dst())
    return out


def src_squares(moves: list[CMove]) -> list[int]:
    out: list[int] = []
    for m in moves:
        f: int = m.frm()
        if f not in out:
            out.append(f)
    return out


def move_index_to(moves: list[CMove], src: int, dst: int) -> int:
    i: int = 0
    while i < len(moves):
        if moves[i].frm() == src and moves[i].dst() == dst:
            return i
        i = i + 1
    return -1


# ── rendering ─────────────────────────────────────────────────────────────────
def ck_cell_bg(r: int, c: int, cur_r: int, cur_c: int, sel_src: int,
               src_dsts: list[int], movable_srcs: list[int]) -> int:
    if r == cur_r and c == cur_c:
        return BG_CURSOR
    sq: int = sq_of(r, c)
    if sel_src != -1 and sq == sel_src:
        return BG_SRC
    if sq in src_dsts:
        return BG_DST
    if sq in movable_srcs:
        return BG_MOVABLE
    if (r + c) % 2 == 1:
        return BG_DARK
    return BG_LIGHT


def ck_draw(s: Screen, pos: list[int], cur_r: int, cur_c: int, sel_src: int,
            src_dsts: list[int], movable_srcs: list[int], side: int,
            status: str, red_left: int, white_left: int) -> None:
    size: tuple[int, int] = s.size()
    cols: int = size[0]
    rows: int = size[1]
    s.clear()
    if cols < MIN_COLS or rows < MIN_ROWS:
        s.set_fg(BRIGHT_RED)
        s.bold(True)
        s.addstr(0, 0, ck_clip("Checkers needs a bigger terminal: " + str(MIN_COLS) + "x" + str(MIN_ROWS) + " min, have " + str(cols) + "x" + str(rows) + ". Resize, then press any key.", cols))
        s.reset_style()
        s.refresh()
        return

    # status bar (row 0, reverse video full width)
    who: str = "YOU (Red)"
    if side == WHITE:
        who = "CPU (White)"
    s.set_fg(BRIGHT_WHITE)
    s.reverse(True)
    s.bold(True)
    bar: str = " CHECKERS    Red(you): " + str(red_left) + "    White(CPU): " + str(white_left) + "    turn: " + who + " "
    s.addstr(0, 0, ck_clip_pad(bar, cols))
    s.reset_style()

    # transient status message (row 1)
    s.set_fg(BRIGHT_YELLOW)
    s.addstr(0, 1, ck_clip(status, cols))
    s.reset_style()

    ox: int = (cols - 8 * CELLW) // 2
    if ox < 3:
        ox = 3
    oy: int = BOARD_Y0

    # file labels (a..h) above and below the board
    s.set_fg(BRIGHT_BLACK)
    c: int = 0
    while c < 8:
        lx: int = ox + c * CELLW + CELLW // 2
        letter: str = chr(ord('a') + c)
        s.addstr(lx, oy - 1, letter)
        s.addstr(lx, oy + 8 * CELLH, letter)
        c = c + 1
    s.reset_style()

    # board: for each square fill its background then draw its piece; rank labels
    # (8..1) flank each row on both sides.
    r: int = 0
    while r < 8:
        ry: int = oy + r * CELLH + CELLH // 2
        s.set_fg(BRIGHT_BLACK)
        s.addstr(ox - 2, ry, str(8 - r))
        s.addstr(ox + 8 * CELLW + 1, ry, str(8 - r))
        s.reset_style()
        c = 0
        while c < 8:
            sq: int = sq_of(r, c)
            bg: int = ck_cell_bg(r, c, cur_r, cur_c, sel_src, src_dsts, movable_srcs)
            x0: int = ox + c * CELLW
            y0: int = oy + r * CELLH
            sub: int = 0
            while sub < CELLH:
                s.set_bg(bg)
                s.addstr(x0, y0 + sub, " " * CELLW)
                sub = sub + 1
            v: int = pos[sq]
            if v != 0:
                fg: int = PIECE_RED_FG
                if piece_side(v) == WHITE:
                    fg = PIECE_WHITE_FG
                s.set_bg(bg)
                s.set_fg(fg)
                if is_king(v):
                    s.bold(True)
                s.addstr(x0 + CELLW // 2, y0 + CELLH // 2, ck_glyph(v))
                s.bold(False)
                s.reset_style()
            c = c + 1
        s.reset_style()
        r = r + 1
    s.reset_style()

    # help / legend line
    help_row: int = oy + 8 * CELLH + 2
    if help_row >= rows:
        help_row = rows - 1
    s.set_fg(BRIGHT_WHITE)
    s.reverse(True)
    s.addstr(0, help_row, ck_clip_pad(" arrows: move cursor    enter/space: select/confirm    esc: deselect    q: quit ", cols))
    s.reset_style()
    s.refresh()


# ── interactive turn: arrow-cursor piece + destination selection ──────────────
def player_pick_move(s: Screen, pos: list[int], moves: list[CMove], side: int,
                     red_left: int, white_left: int, intro: str,
                     start_r: int, start_c: int) -> tuple[int, int, int]:
    """Player's turn. Returns (move_index_into_moves, cursor_r, cursor_c); the
    move index is -1 when the player quits (q / Esc-with-nothing-selected /
    Ctrl+C). Legal destinations are highlighted by reusing the pure move list."""
    cur_r: int = start_r
    cur_c: int = start_c
    sel_src: int = -1
    forced: bool = len(moves) > 0 and moves[0].is_jump()
    base_status: str = intro
    if forced:
        base_status = base_status + "  Captures are forced!"
    status: str = base_status

    while True:
        movable: list[int] = []
        dsts: list[int] = []
        if sel_src == -1:
            movable = src_squares(moves)
        else:
            dsts = dsts_of(moves_from(moves, sel_src))
        ck_draw(s, pos, cur_r, cur_c, sel_src, dsts, movable, side, status, red_left, white_left)

        k: str = s.getch()
        if k == "q" or k == "ctrl+c":
            return (-1, cur_r, cur_c)
        elif k == "up":
            if cur_r > 0:
                cur_r = cur_r - 1
        elif k == "down":
            if cur_r < 7:
                cur_r = cur_r + 1
        elif k == "left":
            if cur_c > 0:
                cur_c = cur_c - 1
        elif k == "right":
            if cur_c < 7:
                cur_c = cur_c + 1
        elif k == "esc":
            if sel_src != -1:
                sel_src = -1
                status = base_status
            else:
                return (-1, cur_r, cur_c)
        elif k == "enter" or k == "space":
            cur_sq: int = sq_of(cur_r, cur_c)
            if sel_src == -1:
                cand: list[CMove] = moves_from(moves, cur_sq)
                if len(cand) > 0:
                    sel_src = cur_sq
                    status = "Selected " + alg(cur_sq) + " — pick a green destination. Esc to deselect."
                else:
                    status = "No legal move from " + alg(cur_sq) + ".  " + base_status
            else:
                mi: int = move_index_to(moves, sel_src, cur_sq)
                if mi >= 0:
                    return (mi, cur_r, cur_c)
                elif cur_sq == sel_src:
                    sel_src = -1
                    status = base_status
                else:
                    cand2: list[CMove] = moves_from(moves, cur_sq)
                    if len(cand2) > 0:
                        sel_src = cur_sq
                        status = "Selected " + alg(cur_sq) + " — pick a green destination. Esc to deselect."
                    else:
                        status = alg(cur_sq) + " is not a legal destination. Esc to deselect."
        # any other key is ignored


def run_checkers(s: Screen) -> None:
    pos: list[int] = new_board()
    side: int = RED  # player (Red) moves first
    no_capture_plies: int = 0
    cur_r: int = 5   # start the cursor on a Red man (row 5, col 0 is a dark sq)
    cur_c: int = 0
    intro: str = "You are Red (r/R), moving up the board."

    while True:
        red_left: int = count_pieces(pos, RED)
        white_left: int = count_pieces(pos, WHITE)
        moves: list[CMove] = gen_moves(pos, side)

        if len(moves) == 0:
            end_msg: str = "CPU has no legal moves. You win!  Press any key to return to the menu."
            if side == RED:
                end_msg = "You have no legal moves. White (CPU) wins!  Press any key to return to the menu."
            ck_draw(s, pos, -1, -1, -1, [], [], side, end_msg, red_left, white_left)
            ignored0: str = s.getch()
            return
        if no_capture_plies >= 40:
            ck_draw(s, pos, -1, -1, -1, [], [], side, "Draw: 40 plies without a capture. Press any key to return to the menu.", red_left, white_left)
            ignored1: str = s.getch()
            return

        if side == RED:
            picked: tuple[int, int, int] = player_pick_move(s, pos, moves, side, red_left, white_left, intro, cur_r, cur_c)
            idx: int = picked[0]
            cur_r = picked[1]
            cur_c = picked[2]
            if idx < 0:
                return  # quit back to the menu
            chosen: CMove = moves[idx]
            pos = ck_apply_move(pos, side, chosen)
            if chosen.is_jump():
                no_capture_plies = 0
            else:
                no_capture_plies = no_capture_plies + 1
            intro = "You played " + chosen.label() + "."
            side = -side
        else:
            # CPU turn: show the "thinking" frame first (it stays on screen while
            # the blocking minimax search runs), then apply the chosen move.
            think: str = intro + "  CPU (White) is thinking..." if intro != "" else "CPU (White) is thinking..."
            ck_draw(s, pos, -1, -1, -1, [], [], side, think, red_left, white_left)
            cidx: int = choose_cpu_move(pos, side, CPU_DEPTH)
            chosen2: CMove = moves[cidx]
            pos = ck_apply_move(pos, side, chosen2)
            if chosen2.is_jump():
                no_capture_plies = 0
            else:
                no_capture_plies = no_capture_plies + 1
            intro = "CPU played " + chosen2.label() + ". Your move."
            side = -side


def play_checkers(s: Screen) -> None:
    # The shared alt-screen session is owned by main (one Screen for the whole
    # app): we just run the game on the passed-in `s` and return to the menu when
    # the player quits or the game ends. main handles init()/close() and the
    # non-TTY degrade; there is nothing to set up or tear down here.
    run_checkers(s)
