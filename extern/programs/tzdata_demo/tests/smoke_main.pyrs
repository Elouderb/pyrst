# tests/smoke_main.pyrs — smoke test for tzdata_demo's built `main` binary.
#
# Drives the compiled binary via subprocess.run (the same pattern as
# extern/programs/pyrstdb's tests — see that README's rationale note on why
# tests here drive the BUILT BINARY rather than importing pyrst modules
# directly across program/package boundaries). Build both binaries first:
#
#   PYRST_PATH=/home/ethos/Coding/pyrst/extern/packages \
#     /home/ethos/Coding/pyrst/target/release/pyrst build main.pyrs
#   /home/ethos/Coding/pyrst/target/release/pyrst build tests/smoke_main.pyrs
#   ./smoke_main                 (optional arg: path to the `main` binary, default "./main")
#
# Prints PASS: smoke_main / exits 0 on success, or FAIL: <reason> / exits
# nonzero.

import sys
from subprocess import run, CompletedProcess


def main() -> None:
    binary: str = "./main"
    if len(sys.argv) > 1:
        binary = sys.argv[1]

    result: CompletedProcess = run([binary], capture_output=True)
    stdout_bytes = result.stdout
    out: str = ""
    if stdout_bytes is not None:
        out = stdout_bytes.decode()

    # Expected lines are oracle-pinned (python3.12 zoneinfo) for the demo's
    # fixed reference instant UTC 2026-07-15 12:00 — local time / offset / DST
    # for each city. Whitespace-collapsed before matching so column padding in
    # the demo is not load-bearing here.
    collapsed: str = ""
    prev_space: bool = False
    for ch in out:
        if ch == " ":
            if not prev_space:
                collapsed = collapsed + " "
            prev_space = True
        else:
            collapsed = collapsed + ch
            prev_space = False

    failures: list[str] = []
    if result.returncode != 0:
        failures.append("main exited " + str(result.returncode) + ", want 0")
    if "tzdata world clock" not in out:
        failures.append("missing header line in output")
    if "reference instant (UTC): 2026-07-15 12:00" not in out:
        failures.append("missing/incorrect reference-instant line")
    if "curated zones available: 74" not in out:
        failures.append("missing/incorrect zone-count line")
    # New York: UTC 12:00 -> local 08:00 EDT, UTC-04:00, DST.
    if "New York 2026-07-15 08:00 UTC-04:00 DST" not in collapsed:
        failures.append("missing/incorrect New York world-clock line")
    # Tokyo: UTC 12:00 -> local 21:00 JST, UTC+09:00, std (no DST).
    if "Tokyo 2026-07-15 21:00 UTC+09:00 std" not in collapsed:
        failures.append("missing/incorrect Tokyo world-clock line")
    # Auckland: UTC 12:00 -> local next-day 00:00 NZST, UTC+12:00, std
    # (exercises day rollover).
    if "Auckland 2026-07-16 00:00 UTC+12:00 std" not in collapsed:
        failures.append("missing/incorrect Auckland world-clock line")

    if len(failures) == 0:
        print("PASS: smoke_main")
    else:
        for f in failures:
            print("FAIL: " + f)
        sys.exit(1)


main()
