# e2e_holdem.pyrs — scripted-stdin end-to-end run of hold'em through the
# real menu (main): one full hand call/check to showdown, decline replay,
# quit.
#
# USAGE (from extern/programs/tabletop/):
#   pyrst build main.pyrs
#   pyrst build tests/e2e_holdem.pyrs
#   printf "2\ncall\ncall\ncall\ncall\ncall\ncall\ncall\ncall\nn\n5\n" | ./e2e_holdem
#
# Script: "2" picks Hold'em, repeated "call" carries the hand through the
# preflop raise/reopen, flop/turn/river checks, to showdown; "n" declines
# another hand, "5" quits. Manually verified: correct pot math, side/showdown
# hand-strength labels (e.g. "Pair" vs "High Card"), and chip totals after
# the hand balance against the starting stacks.
#
# Same subprocess stdio-inheritance workaround as tests/smoke_main.pyrs
# (GAP: subprocess.run has no input= piping) — only the exit code is
# asserted here; correctness of the printed hand was verified manually.
import subprocess


def main() -> None:
    result = subprocess.run(["./main"], capture_output=False)
    if result.returncode == 0:
        print("PASS: hold'em scripted hand ran to showdown (exit 0)")
    else:
        print(f"FAIL: main exited with code {result.returncode}")
        assert False
