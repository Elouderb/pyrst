# fail_gen_reversed.pyrs
# reversed(g) on a lazy generator is an honest MATERIALIZE error at typeck.
# A generator is single-pass with no backward iteration; reversed(gen) is a
# TypeError in CPython too. Expected substring: "cannot be reversed".

def gen(n: int) -> Iterator[int]:
    i: int = 0
    while i < n:
        yield i
        i = i + 1


def main() -> None:
    g: Iterator[int] = gen(3)
    for x in reversed(g):         # ERROR: reversed(list(g))
        print(x)
