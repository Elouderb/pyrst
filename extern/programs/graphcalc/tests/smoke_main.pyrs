# smoke_main.pyrs — "build + run main under non-tty stdin, expect a clean exit"
# smoke test.
#
# USAGE (from extern/programs/graphcalc/):
#   pyrst build main.pyrs
#   pyrst build tests/smoke_main.pyrs
#   printf '' | ./smoke_main        # or any piped/redirected (non-tty) stdin
#
# WHAT THIS NOW EXERCISES (card 4cb345cf): main.pyrs is an INTERACTIVE terminal
# program (the `terminal` package's alternate screen + raw mode), no longer a
# line REPL. When stdin is NOT a real terminal — exactly the case here, since
# `subprocess.run([...], capture_output=False)` inherits this process's own
# (piped) stdio — the terminal package's `Screen.init()` raises an
# `OSError` ("could not enable raw mode ..."), which `main()` catches and turns
# into an honest one-line message + exit 0 (the non-tty DEGRADE path). So this
# test asserts that path: a non-tty invocation neither hangs nor crashes and
# exits cleanly, before the alt screen is ever entered (so the terminal is never
# left in raw mode). It does NOT drive the interactive UI — that is covered by
# pty-driven verification (lead + code review of card 4cb345cf: normal quit,
# Ctrl+C, too-small terminal, edit-cancel, and mid-session parse error all
# restore the terminal and exit 0). Plot/parse/eval CORRECTNESS lives in
# test_rasterizer / test_parser / test_evaluator (pure functions, no subprocess).
import subprocess


def main() -> None:
    result = subprocess.run(["./main"], capture_output=False)
    if result.returncode == 0:
        print("PASS: main degraded cleanly under non-tty stdin (exit 0)")
    else:
        print(f"FAIL: main exited with code {result.returncode}")
        assert False
