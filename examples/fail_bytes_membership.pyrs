# W5-a HONEST REJECTION: membership over a `bytes` container is deferred to the
# bytes-method wave. This also closes the mismatched-`in` hole — `"A" in b"ABC"`
# is a CPython TypeError ("a bytes-like object is required, not 'str'") — without
# letting the loose generic membership path leak a rustc error.
def main() -> None:
    print("A" in b"ABC")
