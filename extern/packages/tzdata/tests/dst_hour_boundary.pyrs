# dst_hour_boundary.pyrs — precise +/-1h transition-hour probes (card 965bf13f).
#
# oracle_matrix.pyrs already covers all 74 zones at noon on the day BEFORE and
# the day AFTER each real 2026 DST transition, which proves the transition
# DATE is right. This file adds a narrower, complementary check: the exact
# WALL-CLOCK HOUR +/-1h around the transition instant, one representative zone
# per DST rule family (the rule — and thus the transition arithmetic — is
# shared within a family; see data.pyrs's family comments), to prove the
# transition HOUR (`local_time_min`) is right, not just the date. Per the
# documented GAP (api.pyrs / data.pyrs module headers), the exact
# ambiguous/nonexistent hour itself is skipped — every probe here is a full
# hour away from the transition, safely outside that window for every family
# below (all have >= 1h gap/overlap).
#
# Every value extracted from python3.12 zoneinfo:
#   from zoneinfo import ZoneInfo; from datetime import datetime
#   datetime(y,m,d,hh,mm,tzinfo=ZoneInfo(name)).utcoffset()/.dst()
#
# Build from the package dir:
#   PYRST_PATH=/home/ethos/Coding/pyrst/extern/packages \
#     /home/ethos/Coding/pyrst/target/release/pyrst build tests/dst_hour_boundary.pyrs
#   ./dst_hour_boundary

import sys
from tzdata.api import utc_offset_at, is_dst_at


def check(label: str, got: int, want: int, failures: Mut[list[str]]) -> None:
    if got != want:
        failures.append(label + ": got " + str(got) + ", want " + str(want))


def check_bool(label: str, got: bool, want: bool, failures: Mut[list[str]]) -> None:
    if got != want:
        failures.append(label + ": got " + str(got) + ", want " + str(want))


def main() -> None:
    failures: list[str] = []

    # ---- US/Canada rule (America/New_York): 2nd Sun Mar 02:00 -> 03:00 local
    # spring; 1st Sun Nov 02:00(DST) -> 01:00(std, fold) fall.
    # Oracle: 2026-03-08 01:00 -300/False, 03:00 -240/True.
    #         2026-11-01 00:00 -240/True, 03:00 -300/False.
    check("NY spring -1h (03-08 01:00)", utc_offset_at("America/New_York", 2026, 3, 8, 1, 0), -300, failures)
    check_bool("NY spring -1h dst", is_dst_at("America/New_York", 2026, 3, 8, 1, 0), False, failures)
    check("NY spring +1h (03-08 03:00)", utc_offset_at("America/New_York", 2026, 3, 8, 3, 0), -240, failures)
    check_bool("NY spring +1h dst", is_dst_at("America/New_York", 2026, 3, 8, 3, 0), True, failures)
    check("NY fall -1h (11-01 00:00)", utc_offset_at("America/New_York", 2026, 11, 1, 0, 0), -240, failures)
    check_bool("NY fall -1h dst", is_dst_at("America/New_York", 2026, 11, 1, 0, 0), True, failures)
    check("NY fall +1h (11-01 03:00)", utc_offset_at("America/New_York", 2026, 11, 1, 3, 0), -300, failures)
    check_bool("NY fall +1h dst", is_dst_at("America/New_York", 2026, 11, 1, 3, 0), False, failures)

    # ---- EU WET rule (Europe/London): last Sun Mar 01:00 -> 02:00 spring;
    # last Sun Oct 02:00(DST) -> ...(fold) fall.
    # Oracle: 2026-03-29 00:00 0/False, 02:00 60/True.
    #         2026-10-25 01:00 60/True, 03:00 0/False.
    check("London spring -1h (03-29 00:00)", utc_offset_at("Europe/London", 2026, 3, 29, 0, 0), 0, failures)
    check_bool("London spring -1h dst", is_dst_at("Europe/London", 2026, 3, 29, 0, 0), False, failures)
    check("London spring +1h (03-29 02:00)", utc_offset_at("Europe/London", 2026, 3, 29, 2, 0), 60, failures)
    check_bool("London spring +1h dst", is_dst_at("Europe/London", 2026, 3, 29, 2, 0), True, failures)
    check("London fall -1h (10-25 01:00)", utc_offset_at("Europe/London", 2026, 10, 25, 1, 0), 60, failures)
    check_bool("London fall -1h dst", is_dst_at("Europe/London", 2026, 10, 25, 1, 0), True, failures)
    check("London fall +1h (10-25 03:00)", utc_offset_at("Europe/London", 2026, 10, 25, 3, 0), 0, failures)
    check_bool("London fall +1h dst", is_dst_at("Europe/London", 2026, 10, 25, 3, 0), False, failures)

    # ---- EU CET rule (Europe/Berlin): last Sun Mar 02:00 -> 03:00 spring;
    # last Sun Oct 03:00(DST) -> ...(fold) fall.
    # Oracle: 2026-03-29 01:00 60/False, 03:00 120/True.
    #         2026-10-25 02:00 120/True, 04:00 60/False.
    check("Berlin spring -1h (03-29 01:00)", utc_offset_at("Europe/Berlin", 2026, 3, 29, 1, 0), 60, failures)
    check_bool("Berlin spring -1h dst", is_dst_at("Europe/Berlin", 2026, 3, 29, 1, 0), False, failures)
    check("Berlin spring +1h (03-29 03:00)", utc_offset_at("Europe/Berlin", 2026, 3, 29, 3, 0), 120, failures)
    check_bool("Berlin spring +1h dst", is_dst_at("Europe/Berlin", 2026, 3, 29, 3, 0), True, failures)
    check("Berlin fall -1h (10-25 02:00)", utc_offset_at("Europe/Berlin", 2026, 10, 25, 2, 0), 120, failures)
    check_bool("Berlin fall -1h dst", is_dst_at("Europe/Berlin", 2026, 10, 25, 2, 0), True, failures)
    check("Berlin fall +1h (10-25 04:00)", utc_offset_at("Europe/Berlin", 2026, 10, 25, 4, 0), 60, failures)
    check_bool("Berlin fall +1h dst", is_dst_at("Europe/Berlin", 2026, 10, 25, 4, 0), False, failures)

    # ---- EU EET rule (Europe/Athens): last Sun Mar 03:00 -> 04:00 spring;
    # last Sun Oct 04:00(DST) -> ...(fold) fall.
    # Oracle: 2026-03-29 02:00 120/False, 04:00 180/True.
    #         2026-10-25 03:00 180/True, 05:00 120/False.
    check("Athens spring -1h (03-29 02:00)", utc_offset_at("Europe/Athens", 2026, 3, 29, 2, 0), 120, failures)
    check_bool("Athens spring -1h dst", is_dst_at("Europe/Athens", 2026, 3, 29, 2, 0), False, failures)
    check("Athens spring +1h (03-29 04:00)", utc_offset_at("Europe/Athens", 2026, 3, 29, 4, 0), 180, failures)
    check_bool("Athens spring +1h dst", is_dst_at("Europe/Athens", 2026, 3, 29, 4, 0), True, failures)
    check("Athens fall -1h (10-25 03:00)", utc_offset_at("Europe/Athens", 2026, 10, 25, 3, 0), 180, failures)
    check_bool("Athens fall -1h dst", is_dst_at("Europe/Athens", 2026, 10, 25, 3, 0), True, failures)
    check("Athens fall +1h (10-25 05:00)", utc_offset_at("Europe/Athens", 2026, 10, 25, 5, 0), 120, failures)
    check_bool("Athens fall +1h dst", is_dst_at("Europe/Athens", 2026, 10, 25, 5, 0), False, failures)

    # ---- Australia E/C rule (Australia/Sydney): 1st Sun Oct 02:00 -> 03:00
    # (DST starts, year-wrapping); 1st Sun Apr 03:00(DST) -> 02:00(std) ends.
    # Oracle: 2026-10-04 01:00 600/False, 03:00 660/True.
    #         2026-04-05 03:00 600/False (post-transition); is_dst_at at 02:00
    #         still DST (660/True, pre-transition).
    check("Sydney start -1h (10-04 01:00)", utc_offset_at("Australia/Sydney", 2026, 10, 4, 1, 0), 600, failures)
    check_bool("Sydney start -1h dst", is_dst_at("Australia/Sydney", 2026, 10, 4, 1, 0), False, failures)
    check("Sydney start +1h (10-04 03:00)", utc_offset_at("Australia/Sydney", 2026, 10, 4, 3, 0), 660, failures)
    check_bool("Sydney start +1h dst", is_dst_at("Australia/Sydney", 2026, 10, 4, 3, 0), True, failures)
    check("Sydney end -1h (04-05 02:00)", utc_offset_at("Australia/Sydney", 2026, 4, 5, 2, 0), 660, failures)
    check_bool("Sydney end -1h dst", is_dst_at("Australia/Sydney", 2026, 4, 5, 2, 0), True, failures)
    check("Sydney end +1h (04-05 03:00)", utc_offset_at("Australia/Sydney", 2026, 4, 5, 3, 0), 600, failures)
    check_bool("Sydney end +1h dst", is_dst_at("Australia/Sydney", 2026, 4, 5, 3, 0), False, failures)

    # ---- New Zealand rule (Pacific/Auckland): last Sun Sep 02:00 -> 03:00
    # starts; 1st Sun Apr 03:00(DST) -> 02:00(std) ends.
    # Oracle: 2026-09-27 01:00 720/False, 03:00 780/True.
    #         2026-04-05 02:00 780/True, 03:00 720/False.
    check("Auckland start -1h (09-27 01:00)", utc_offset_at("Pacific/Auckland", 2026, 9, 27, 1, 0), 720, failures)
    check_bool("Auckland start -1h dst", is_dst_at("Pacific/Auckland", 2026, 9, 27, 1, 0), False, failures)
    check("Auckland start +1h (09-27 03:00)", utc_offset_at("Pacific/Auckland", 2026, 9, 27, 3, 0), 780, failures)
    check_bool("Auckland start +1h dst", is_dst_at("Pacific/Auckland", 2026, 9, 27, 3, 0), True, failures)
    check("Auckland end -1h (04-05 02:00)", utc_offset_at("Pacific/Auckland", 2026, 4, 5, 2, 0), 780, failures)
    check_bool("Auckland end -1h dst", is_dst_at("Pacific/Auckland", 2026, 4, 5, 2, 0), True, failures)
    check("Auckland end +1h (04-05 03:00)", utc_offset_at("Pacific/Auckland", 2026, 4, 5, 3, 0), 720, failures)
    check_bool("Auckland end +1h dst", is_dst_at("Pacific/Auckland", 2026, 4, 5, 3, 0), False, failures)

    # ---- Chile rule (America/Santiago): 1st Sat Sep 24:00(==Sun 00:00)
    # starts DST; 1st Sat Apr 24:00 ends DST. 2026: 1st Sat Sep = Sep 5, 1st
    # Sat Apr = Apr 4.
    # Oracle: 2026-09-05 23:00 -240/False, 2026-09-06 01:00 -180/True.
    #         2026-04-04 23:00 -180/True, 2026-04-05 01:00 -240/False.
    check("Santiago start -1h (09-05 23:00)", utc_offset_at("America/Santiago", 2026, 9, 5, 23, 0), -240, failures)
    check_bool("Santiago start -1h dst", is_dst_at("America/Santiago", 2026, 9, 5, 23, 0), False, failures)
    check("Santiago start +1h (09-06 01:00)", utc_offset_at("America/Santiago", 2026, 9, 6, 1, 0), -180, failures)
    check_bool("Santiago start +1h dst", is_dst_at("America/Santiago", 2026, 9, 6, 1, 0), True, failures)
    check("Santiago end -1h (04-04 23:00)", utc_offset_at("America/Santiago", 2026, 4, 4, 23, 0), -180, failures)
    check_bool("Santiago end -1h dst", is_dst_at("America/Santiago", 2026, 4, 4, 23, 0), True, failures)
    check("Santiago end +1h (04-05 01:00)", utc_offset_at("America/Santiago", 2026, 4, 5, 1, 0), -240, failures)
    check_bool("Santiago end +1h dst", is_dst_at("America/Santiago", 2026, 4, 5, 1, 0), False, failures)

    if len(failures) == 0:
        print("PASS: dst_hour_boundary")
    else:
        for f in failures:
            print("FAIL: " + f)
        sys.exit(1)


main()
