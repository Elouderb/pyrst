# main.pyrs — tabletop game sim: a single-screen live menu shell.
#
# Live-board retrofit (card 73098a55): the WHOLE app runs as ONE `terminal`
# alt-screen session. main creates the Screen, init()s it ONCE (with an OSError ->
# honest degrade if there is no TTY, as for the scripted-stdin tests), runs the
# menu on it, dispatches to the games on the SAME shared Screen, and close()s it
# ONCE in a finally so the terminal is ALWAYS restored.
#
# As of PASS 3 ALL FOUR games — blackjack, hold'em, checkers, chess — are live
# in-place boards/tables drawn directly on the shared Screen. The temporary
# suspend/resume "bridge" that carried the still-line-based card games in PASS 2
# is GONE: every game is dispatched directly, so there is exactly ONE
# enter/leave-alternate-screen for the whole app (no re-init mid-run).
#
# Because the live menu itself needs a real terminal, a piped/redirected stdin
# (the tests) makes init() raise before entering the alt screen; main prints an
# honest one-liner and exits 0 instead of hanging.
#
# COORDINATES are (x, y) = (col, row), 0-based (the terminal convention).
from terminal import Screen
import ttscreen
import blackjack
import holdem
import checkers
import chess

DEFAULT_SEED: int = 42

MENU_TITLE: str = "Tabletop Game Sim"
MENU_OPTIONS: list[str] = [
    "Blackjack     (player + 2 CPU seats)",
    "Texas Hold'em (player + 2 CPU seats)",
    "Checkers      (vs CPU)",
    "Chess         (vs CPU)",
    "Quit",
]


def activate(s: Screen, choice: int) -> bool:
    # Run the chosen menu option (0-based) on the shared Screen. Returns True iff
    # the app should quit. Every game draws live in-place and returns to the menu
    # on quit — no suspend/resume bridge (all four are on the terminal library).
    if choice == 0:
        blackjack.play_blackjack(s, DEFAULT_SEED)
    elif choice == 1:
        holdem.play_holdem(s, DEFAULT_SEED)
    elif choice == 2:
        checkers.play_checkers(s)
    elif choice == 3:
        chess.play_chess(s)
    else:
        return True
    return False


def menu_loop(s: Screen) -> None:
    sel: int = 0
    n: int = len(MENU_OPTIONS)
    while True:
        ttscreen.draw_menu(s, MENU_TITLE, MENU_OPTIONS, sel)
        k: str = s.getch()
        if k == "q" or k == "ctrl+c" or k == "esc":
            return
        elif k == "up":
            sel = (sel - 1 + n) % n
        elif k == "down":
            sel = (sel + 1) % n
        elif k == "enter" or k == "space":
            if activate(s, sel):
                return
        elif k == "1" or k == "2" or k == "3" or k == "4" or k == "5":
            sel = int(k) - 1
            if activate(s, sel):
                return
        # any other key is ignored


def main() -> None:
    s: Screen = Screen()
    try:
        s.init()
    except OSError as e:
        # Not a TTY (piped/redirected — e.g. the scripted-stdin tests): the live
        # menu needs a real terminal, so degrade honestly instead of hanging.
        # init() raises BEFORE entering the alt screen, so nothing to restore.
        print("Tabletop Game Sim now runs on a live board and needs a real terminal (a TTY).")
        print("Run it directly in your terminal:  ./main")
        print("detail: " + e)
        return
    try:
        menu_loop(s)
    finally:
        s.close()  # ALWAYS restores: raw mode off, leaves the alt screen, cursor shown
    print("Tabletop — terminal restored. Goodbye.")
