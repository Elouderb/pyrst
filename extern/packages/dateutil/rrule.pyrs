# rrule.pyrs — pyrst-dateutil's `dateutil.rrule` subset (card 0223a4b8).
# CORE IMPL (complex-implementer).
#
# SCOPE: DAILY/WEEKLY/MONTHLY/YEARLY `freq` + `interval` + `count`/`until`
# + `byweekday` + `bymonthday`. HOURLY/MINUTELY/SECONDLY are OUT OF SCOPE
# (constants kept for CPython naming fidelity; rejected at construction).
#
# BY-RULE SCOPE (honest, oracle-pinned): `byweekday` is supported for DAILY
# and WEEKLY; `bymonthday` for MONTHLY. Any other freq×by-rule combination
# is an out-of-tested-scope `NotImplementedError` at construction (rather
# than a silent divergence) — see `__init__`.
#
# EXPANSION MODEL (matches dateutil for this subset): a recurrence walks
# "periods" (a day/week/month/year, advanced by `interval`) and, within each
# period, enumerates candidate instants filtered by the BY-rules, in
# chronological order, keeping those >= dtstart until `count`/`until`. It is a
# FILTER model, NOT a clamp: MONTHLY from Jan-31 yields Jan-31, Mar-31,
# May-31, Jul-31 (SKIPPING months with no 31st); YEARLY from Feb-29 yields
# only leap years. The time-of-day is fixed to dtstart's (this subset carries
# no byhour/byminute/bysecond). dtstart itself is emitted first only if it
# satisfies the BY-rules. Oracle probes are pinned in tests/.
#
# GENERATOR-METHOD GAP: pyrst has no `yield` inside a class method, so the
# lazy sequence is the FREE FUNCTION `iterate(rule) -> Iterator[datetime]`,
# not an `rrule.__iter__`. `materialize(rule, limit)` is the eager
# `list(rrule(...))` equivalent (REQUIRES a `limit`: a count-less, until-less
# rule is legitimately infinite, exactly as in dateutil).

from datetime import datetime, timedelta
from dateutil.relativedelta import MO, TU, WE, TH, FR, SA, SU, Weekday


YEARLY: int = 0
MONTHLY: int = 1
WEEKLY: int = 2
DAILY: int = 3
HOURLY: int = 4
MINUTELY: int = 5
SECONDLY: int = 6


def _freq_in_scope(freq: int) -> bool:
    return freq == DAILY or freq == WEEKLY or freq == MONTHLY or freq == YEARLY


def _rr_is_leap(y: int) -> bool:
    return (y % 4 == 0 and y % 100 != 0) or (y % 400 == 0)


def _rr_days_in_month(y: int, m: int) -> int:
    if m == 2:
        if _rr_is_leap(y):
            return 29
        return 28
    if m == 4 or m == 6 or m == 9 or m == 11:
        return 30
    return 31


class rrule:
    freq: int
    dtstart: datetime
    interval: int
    count: Optional[int]
    until: Optional[datetime]
    byweekday: Optional[list[int]]
    bymonthday: Optional[list[int]]

    def __init__(
        self,
        freq: int,
        dtstart: datetime,
        interval: int = 1,
        count: Optional[int] = None,
        until: Optional[datetime] = None,
        byweekday: Optional[list[int]] = None,
        bymonthday: Optional[list[int]] = None
    ) -> None:
        if not _freq_in_scope(freq):
            raise NotImplementedError(
                "rrule: freq=" + str(freq) + " (HOURLY/MINUTELY/SECONDLY) is out of scope, see card 0223a4b8"
            )
        if count is not None and until is not None:
            raise ValueError("rrule: count and until are mutually exclusive")
        if interval < 1:
            raise ValueError("rrule: interval must be >= 1")
        # BY-rule scope guards (oracle-pinned combinations only).
        if byweekday is not None:
            if freq != DAILY and freq != WEEKLY:
                raise NotImplementedError(
                    "rrule: byweekday is supported only for DAILY/WEEKLY in this subset, see card 0223a4b8"
                )
        if bymonthday is not None:
            if freq != MONTHLY:
                raise NotImplementedError(
                    "rrule: bymonthday is supported only for MONTHLY in this subset, see card 0223a4b8"
                )
        self.freq = freq
        self.dtstart = dtstart
        self.interval = interval
        self.count = count
        self.until = until
        self.byweekday = byweekday
        self.bymonthday = bymonthday


def _safe_add_days(dt: datetime, days: int) -> Optional[datetime]:
    try:
        return dt + timedelta(days=days)
    except OverflowError:
        return None
    except ValueError:
        return None


def _safe_make(y: int, m: int, d: int, proto: datetime) -> Optional[datetime]:
    try:
        return datetime(y, m, d, proto.hour, proto.minute, proto.second, proto.microsecond)
    except ValueError:
        return None


def _advance_month(y: int, m: int, delta: int) -> tuple[int, int]:
    total: int = (m - 1) + delta
    y2: int = y + total // 12
    m2: int = total % 12 + 1
    return (y2, m2)


def _sorted_ints(xs: list[int]) -> list[int]:
    # Small insertion sort (ascending) — the bymonthday candidate set is tiny.
    out: list[int] = []
    for v in xs:
        i: int = 0
        while i < len(out) and out[i] < v:
            i = i + 1
        out.insert(i, v)
    return out


def _monthdays(rule: rrule, y: int, m: int) -> list[int]:
    bmd: Optional[list[int]] = rule.bymonthday
    if bmd is None:
        return [rule.dtstart.day]
    dim: int = _rr_days_in_month(y, m)
    resolved: list[int] = []
    for md in bmd:
        actual: int = md
        if md < 0:
            actual = dim + 1 + md
        if actual >= 1 and actual <= dim:
            resolved.append(actual)
    return _sorted_ints(resolved)


def _passes_byweekday(rule: rrule, dt: datetime) -> bool:
    bw: Optional[list[int]] = rule.byweekday
    if bw is None:
        return dt.weekday() == rule.dtstart.weekday()
    return dt.weekday() in bw


def _daily_passes(rule: rrule, dt: datetime) -> bool:
    bw: Optional[list[int]] = rule.byweekday
    if bw is None:
        return True
    return dt.weekday() in bw


def _period_candidates(rule: rrule, k: int) -> list[datetime]:
    out: list[datetime] = []
    ds: datetime = rule.dtstart
    iv: int = rule.interval
    f: int = rule.freq
    if f == DAILY:
        c: Optional[datetime] = _safe_add_days(ds, k * iv)
        if c is not None:
            cc: datetime = c
            if _daily_passes(rule, cc):
                out.append(cc)
    elif f == WEEKLY:
        week_off: int = -ds.weekday() + k * iv * 7
        base: Optional[datetime] = _safe_add_days(ds, week_off)
        if base is not None:
            b: datetime = base
            i: int = 0
            while i < 7:
                day: Optional[datetime] = _safe_add_days(b, i)
                if day is not None:
                    d2: datetime = day
                    if _passes_byweekday(rule, d2):
                        out.append(d2)
                i = i + 1
    elif f == MONTHLY:
        ym: tuple[int, int] = _advance_month(ds.year, ds.month, k * iv)
        days: list[int] = _monthdays(rule, ym[0], ym[1])
        for dd in days:
            c2: Optional[datetime] = _safe_make(ym[0], ym[1], dd, ds)
            if c2 is not None:
                out.append(c2)
    else:
        yy: int = ds.year + k * iv
        c3: Optional[datetime] = _safe_make(yy, ds.month, ds.day, ds)
        if c3 is not None:
            out.append(c3)
    return out


def iterate(rule: rrule) -> Iterator[datetime]:
    # Lazy expansion engine (see module header for the model + oracle pins).
    dtstart: datetime = rule.dtstart
    emitted: int = 0
    k: int = 0
    empty_streak: int = 0
    while True:
        cands: list[datetime] = _period_candidates(rule, k)
        produced: bool = False
        for c in cands:
            if c < dtstart:
                continue
            a_until: Optional[datetime] = rule.until
            if a_until is not None:
                lim: datetime = a_until
                if lim < c:
                    return
            yield c
            produced = True
            emitted = emitted + 1
            a_count: Optional[int] = rule.count
            if a_count is not None:
                cc: int = a_count
                if emitted >= cc:
                    return
        if produced:
            empty_streak = 0
        else:
            empty_streak = empty_streak + 1
            # Safety valve: an all-invalid stretch (e.g. running past year
            # 9999, where every candidate construction fails) is bounded. A
            # legitimately-recurring rule never sees this many empty periods
            # in a row (MONTHLY day-31 skips at most 2; YEARLY Feb-29 at most 3).
            if empty_streak > 800:
                return
        k = k + 1


def materialize(rule: rrule, limit: int) -> list[datetime]:
    out: list[datetime] = []
    for dt in iterate(rule):
        if len(out) >= limit:
            break
        out.append(dt)
    return out
