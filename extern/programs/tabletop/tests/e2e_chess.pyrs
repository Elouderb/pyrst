# e2e_chess.pyrs — scripted-stdin end-to-end run through the real menu (main),
# verifying that under a NON-TTY stdin the app degrades honestly and still exits
# cleanly (exit 0, no hang).
#
# As of the live-board retrofit (card 73098a55, PASS 2), chess is a full-screen,
# live in-place board (arrow-cursor two-phase from->to selection, highlighted
# legal destinations, coloured pieces, a Q/R/B/N promotion prompt, a status line),
# reached from a `terminal`-based menu. The whole app is ONE shared Screen that
# MAIN init()s once — and raw mode REQUIRES a real terminal (a TTY). Under
# scripted/piped stdin — as this harness runs it — main.init() raises an
# OSError-shaped exception BEFORE entering the alt screen; main prints an honest
# "needs a real terminal" line and exits 0. The menu never opens, so chess is not
# reached under a pipe.
#
# USAGE (from extern/programs/tabletop/):
#   pyrst build main.pyrs
#   pyrst build tests/e2e_chess.pyrs
#   printf '' | ./e2e_chess         # any piped/redirected stdin degrades main
#
# The interactive chess game (live board, selection, promotion, CPU reply) is
# verified separately by driving a real PTY. Full-game perft / checkmate /
# stalemate correctness stays covered by test_chess.pyrs (published perft counts
# for 5 standard positions + fool's-mate + stalemate). Because main degrades at
# startup under a pipe, the piped bytes are irrelevant (main never reads stdin);
# only the exit code is asserted.
#
# Same subprocess stdio-inheritance workaround as tests/smoke_main.pyrs
# (GAP: subprocess.run has no input= piping).
import subprocess


def main() -> None:
    result = subprocess.run(["./main"], capture_output=False)
    if result.returncode == 0:
        print("PASS: non-tty main degrade (menu needs a TTY) exited cleanly (exit 0)")
    else:
        print(f"FAIL: main exited with code {result.returncode}")
        assert False
