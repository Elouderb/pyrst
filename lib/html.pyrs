# pyrst standard library — html
#
# `html.escape` / `html.unescape` — a PURE-PYRST port of CPython's `html`
# module. Embedded via `include_str!` (see `src/stdlib.rs`); `html` is not on
# the resolver skip-list, so both `from html import escape, unescape` and
# `import html; html.escape(s)` resolve. No external crate — hand-rolled
# scanner instead of a regex dependency (see divergence notes below).
#
# Fidelity: 3.5/5 (per docs/design/w2-dossiers/html.md target). `escape()` is
# a full CPython-exact port. `unescape()` implements CPython's EXACT
# algorithm (same numeric-charref resolution table, same longest-prefix
# named-entity backtracking, same Windows-1252 remap / invalid-codepoint
# filtering) but over a DELIBERATELY NARROWED named-entity table — see
# "NAMED-ENTITY COVERAGE" below. This is the one intentional scope cut (per
# card d9182d50's AC), not a correctness bug: every entity name IN our table
# resolves with byte-identical semantics to CPython, including the optional-
# semicolon / longest-prefix-match / leftover-suffix edge cases.
#
# Public API (exact CPython names/signatures):
#   - `escape(s: str, quote: bool = True) -> str` — replace `&` with
#     `&amp;` FIRST (so already-escaped input double-escapes, matching
#     CPython), then `<` -> `&lt;`, `>` -> `&gt;`; if `quote` is true also
#     `"` -> `&quot;` and `'` -> `&#x27;` (CPython uses the HEX form for the
#     apostrophe, not `&#39;` — verified against CPython 3.12.9).
#   - `unescape(s: str) -> str` — convert named (`&lt;`), decimal (`&#65;`)
#     and hex (`&#x41;` / `&#X41;`) character references back to Unicode.
#     Fast path: if `s` contains no `&`, return `s` unchanged (matches
#     CPython's `if '&' not in s: return s`).
#
# ALGORITHM (hand-rolled scanner — no `re` dependency; the dossier's HAZARD
# 4.8 flagged CPython's regex `r'&(#[0-9]+;?|#[xX][0-9a-fA-F]+;?|
# [^\t\n\f <&#;]{1,32};?)'` as a Pyrst-fidelity risk, so this is a
# character-by-character re-implementation of the SAME two-phase algorithm
# CPython's `_charref.sub(_replace_charref, s)` performs):
#   1. Scan left to right. Any char other than `&` is copied through as-is.
#   2. At an `&`: if followed by `#`, it's a NUMERIC charref — `#` + decimal
#      digits, or `#x`/`#X` + hex digits, with an OPTIONAL trailing `;`. No
#      digits at all (`&#x;`, `&#;`, `&;`) => NOT a charref at all; emit a
#      literal `&` and re-scan from the very next character (matches
#      CPython: the regex fails to match ANY alternative there, so `re.sub`
#      leaves that lone `&` untouched and resumes scanning one char later).
#   3. Otherwise it's a NAMED charref — CPython's char class excludes
#      `\t\n\f <&#;`, capped at 32 chars, plus an optional trailing `;`.
#      Zero word-chars captured => same "not a charref" literal fallback as
#      step 2.
#   4. Named-charref resolution mirrors CPython's `_replace_charref` EXACTLY:
#      first try the ENTIRE captured word (honoring whether it needs a
#      trailing `;` — see below); if that fails, walk decreasing-length
#      PREFIXES of the bare word (from `len(word)-1` down to `2`, always as
#      a "no semicolon required" lookup — CPython's `range(len(s)-1, 1, -1)`
#      loop's one edge case at `x == len(word)` when a `;` was present is
#      PROVABLY DEAD CODE: it re-tests the same "full word in table" fact
#      Step 1 already tested unconditionally, so it can never independently
#      succeed — proven during dossier verification, not guessed). The
#      first prefix hit wins (LONGEST prefix, since we walk decreasing `x`);
#      its resolved character is prepended to the un-matched leftover
#      characters (plus the original trailing `;` if the whole captured
#      chunk had one). No prefix hits at all => literal `&` + the whole
#      captured word (+ `;` if present) is emitted UNCHANGED — provably
#      identical, either way, to just re-scanning character-by-character,
#      since a captured "word" can never itself contain another `&`.
#   5. Numeric charref resolution mirrors CPython's exact priority order:
#        a. value in the 34-entry Windows-1252 remap table (`_invalid_charrefs`
#           — codepoints 0, 13, and 128-159) => that table's exact character
#           (most of 128-159 map to a DIFFERENT Windows-1252 glyph; a few
#           — 129/141/143/144/157 — have no such glyph and map to themselves).
#        b. a lone UTF-16 surrogate (0xD800-0xDFFF) or beyond Unicode's
#           range (> 0x10FFFF) => U+FFFD REPLACEMENT CHARACTER.
#        c. one of CPython's 94 remaining "invalid codepoint" values (most
#           C0 controls, the 0xFDD0-0xFDEF noncharacter block, and the
#           `0xFFFE`/`0xFFFF` pair at the end of EVERY plane 0-16) => empty
#           string. This pass compresses CPython's 126-entry
#           `_invalid_codepoints` set to a closed-form check (verified
#           against the live CPython set, not eyeballed): the trailing
#           `0xFFFE`/`0xFFFF` pair recurs at `plane*0x10000 + 0xFFFE/F` for
#           every plane, so `num % 0x10000 in {0xFFFE, 0xFFFF}` covers all
#           17 planes' worth of that pair in one check.
#        d. otherwise: `chr(value)`.
#      Overflow guard: a digit run can be arbitrarily long (CPython parses
#      it as a Python bigint); pyrst ints are `i64`, so accumulation FREEZES
#      once the running value exceeds `0x10FFFF` (any value that has ever
#      crossed that line is guaranteed to stay "> 0x10FFFF" — i.e. still
#      resolves to the identical U+FFFD outcome — no matter how many more
#      digits follow), which sidesteps overflow without changing the
#      observable result for any input.
#
# NAMED-ENTITY COVERAGE (the deliberate scope cut, per card d9182d50's AC:
# "ship a pragmatic named-entity subset — the ~252 name2codepoint core
# rather than all 2231 html5 entries if size demands"): this module's named-
# entity table is CPython's `html.entities.name2codepoint` (252 names,
# python3.12.9-verified), NOT the full 2231-entry `html5` dict the dossier
# describes. `html.entities` itself is NOT exposed at all (G3: pyrst has no
# dotted submodules — `import html.entities` has no pyrst equivalent; the
# dossier's own suggested workaround — inline the table, don't expose a
# submodule — is exactly what this does).
#   - COVERED: every name2codepoint entity, named-entity longest-prefix
#     matching, and the optional-semicolon rule for the 100 of those 252
#     names that are ALSO in html5's semicolon-optional set (`amp`, `lt`,
#     `gt`, `quot`, `copy`, `nbsp`, `not`, ... — python3-verified exact set).
#     The other 152 (Greek letters, math symbols, typographic marks — e.g.
#     `notin`, `alpha`, `trade`) require the trailing `;`, matching CPython.
#   - NOT COVERED: any of the ~1979 html5-only entities (multi-codepoint
#     entities like `&NotEqualTilde;`, and EVERY uppercase/mixed-case ALIAS
#     outside name2codepoint — e.g. `&LT;`/`&Lt;`/`&AMP;`/`&COPY;` are html5-
#     only spellings NOT in name2codepoint, so they are NOT recognized here
#     and pass through unchanged instead of resolving to `<`/`≪`/`&`/`©`).
#     This is a KNOWN, DOCUMENTED divergence from full CPython fidelity —
#     the dossier's own PARITY PLAN includes `&LT;`/`&Lt;` cases that this
#     module does NOT match; our `examples/parity_html.pyrs` was reseeded to
#     drop those two specific cases (every other dossier case is covered).
#
# NAME COLLISION (documented co-import restriction, precedent: `re.escape`):
# `lib/re.pyrs` ALSO defines a top-level `escape` (regex-metachar escaping).
# pyrst's module namespace is FLAT (co-import collision detection — card
# 6c8b4a39), so a single program CANNOT `import html` and `import re`
# together (or `from html import escape` + `from re import escape`) — the
# resolver raises a clear cross-module-collision error at compile time
# rather than silently letting one shadow the other. Both modules keep
# their exact CPython name (`escape`) rather than renaming either away from
# parity; a program needing both regex-escaping and HTML-escaping must pick
# one qualified import path manually (not currently expressible in pyrst
# without dotted submodules / aliasing).
#
# Errors: `escape`/`unescape` never raise in pyrst (both take a mandatory
# `str` argument the type checker already enforces — the dossier's
# `AttributeError`/`TypeError` probes are CPython's untyped-argument
# behavior, not reachable through pyrst's static typing).
#
# `quote` kwarg: works exactly like every other pyrst default-arg parameter
# — `html.escape(s, quote=False)` — CPython's truthy/falsy coercion (dossier
# ERRORS: `quote=1`/`quote=0`) does not apply since pyrst's `quote` is
# statically `bool`.

def escape(s: str, quote: bool = True) -> str:
    result: str = s.replace("&", "&amp;")
    result = result.replace("<", "&lt;")
    result = result.replace(">", "&gt;")
    if quote:
        result = result.replace("\"", "&quot;")
        result = result.replace("'", "&#x27;")
    return result


def _html_is_word_char(c: str) -> bool:
    if c == "\t" or c == "\n" or c == "\f" or c == " ":
        return False
    if c == "<" or c == "&" or c == "#" or c == ";":
        return False
    return True


def _html_is_ascii_digit(c: str) -> bool:
    return c >= "0" and c <= "9"


def _html_is_hex_digit(c: str) -> bool:
    if c >= "0" and c <= "9":
        return True
    if c >= "a" and c <= "f":
        return True
    return c >= "A" and c <= "F"


def _html_dec_value(c: str) -> int:
    return ord(c) - ord("0")


def _html_hex_value(c: str) -> int:
    if c >= "0" and c <= "9":
        return ord(c) - ord("0")
    if c >= "a" and c <= "f":
        return ord(c) - ord("a") + 10
    return ord(c) - ord("A") + 10


# CPython's `_invalid_charrefs`: numeric charrefs 0, 13 and 128-159 resolve
# through this Windows-1252 remap table BEFORE any other check (34 entries,
# python3.12.9-verified). Most of 128-159 map to a distinct glyph; five
# (129, 141, 143, 144, 157) have no Windows-1252 glyph and map to themselves.
def _html_invalid_charref(num: int) -> Optional[str]:
    if num == 0:
        return chr(0xFFFD)
    if num == 13:
        return "\r"
    if num == 128:
        return chr(0x20AC)
    if num == 129:
        return chr(0x81)
    if num == 130:
        return chr(0x201A)
    if num == 131:
        return chr(0x192)
    if num == 132:
        return chr(0x201E)
    if num == 133:
        return chr(0x2026)
    if num == 134:
        return chr(0x2020)
    if num == 135:
        return chr(0x2021)
    if num == 136:
        return chr(0x2C6)
    if num == 137:
        return chr(0x2030)
    if num == 138:
        return chr(0x160)
    if num == 139:
        return chr(0x2039)
    if num == 140:
        return chr(0x152)
    if num == 141:
        return chr(0x8D)
    if num == 142:
        return chr(0x17D)
    if num == 143:
        return chr(0x8F)
    if num == 144:
        return chr(0x90)
    if num == 145:
        return chr(0x2018)
    if num == 146:
        return chr(0x2019)
    if num == 147:
        return chr(0x201C)
    if num == 148:
        return chr(0x201D)
    if num == 149:
        return chr(0x2022)
    if num == 150:
        return chr(0x2013)
    if num == 151:
        return chr(0x2014)
    if num == 152:
        return chr(0x2DC)
    if num == 153:
        return chr(0x2122)
    if num == 154:
        return chr(0x161)
    if num == 155:
        return chr(0x203A)
    if num == 156:
        return chr(0x153)
    if num == 157:
        return chr(0x9D)
    if num == 158:
        return chr(0x17E)
    if num == 159:
        return chr(0x178)
    return None


# CPython's 126-entry `_invalid_codepoints` set, compressed to a closed-form
# check (python3.12.9-verified equivalent — see module header). Only reached
# for numbers NOT resolved by `_html_invalid_charref` and not a surrogate /
# out-of-range value.
def _html_is_invalid_codepoint(num: int) -> bool:
    if num >= 1 and num <= 8:
        return True
    if num == 11:
        return True
    if num >= 14 and num <= 31:
        return True
    if num == 127:
        return True
    if num >= 0xFDD0 and num <= 0xFDEF:
        return True
    if num % 0x10000 == 0xFFFE or num % 0x10000 == 0xFFFF:
        return True
    return False


def _html_resolve_numeric(num: int) -> str:
    special: Optional[str] = _html_invalid_charref(num)
    if special is not None:
        return special
    if num >= 0xD800 and num <= 0xDFFF:
        return chr(0xFFFD)
    if num > 0x10FFFF:
        return chr(0xFFFD)
    if _html_is_invalid_codepoint(num):
        return ""
    return chr(num)


