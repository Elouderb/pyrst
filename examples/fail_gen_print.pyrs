# fail_gen_print.pyrs
# print(g) on a bare lazy generator is an honest MATERIALIZE error at typeck —
# the print-position format of a generator would show an opaque handle, not its
# contents (like str(g)). Expected substring: "printable form".

def gen(n: int) -> Iterator[int]:
    i: int = 0
    while i < n:
        yield i
        i = i + 1


def main() -> None:
    g: Iterator[int] = gen(3)
    print(g)                      # ERROR: print(list(g))
