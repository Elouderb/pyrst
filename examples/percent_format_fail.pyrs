# W0-a (p05): string %-formatting is an honest CHECK error (not a rustc leak).
# It must suggest an f-string. Integer modulo `a % b` stays legal (see set_algebra
# / arithmetic examples); only a STR left operand is rejected.
def main() -> None:
    x: int = 42
    label: str = "%d apples" % x
    print(label)
